@page
@model ProyectoMSD.Pages.Dispositivos.DetailsModel

@{
    ViewData["Title"] = "Detalles del Dispositivo";
}

@section Styles {
    <link href="~/css/pages/dispositivos.css" rel="stylesheet" />
}

<div class="main-container" style="max-width: 800px;">
    <!-- Header -->
    <div class="profile-header glass-card-header" style="border-bottom: 2px solid var(--primary-blue, #4a90e2);">
        <div class="d-flex align-items-center">
            <div class="position-relative me-4">
                <div class="device-icon" style="width:100px; height:100px; background:rgba(74, 144, 226, 0.1); border:2px solid rgba(74, 144, 226, 0.3); border-radius:20px; display:flex; align-items:center; justify-content:center; font-size:2.5rem; color:var(--primary-blue, #4a90e2);">
                    <i class="fas fa-mobile-alt"></i>
                </div>
            </div>
            <div class="flex-grow-1">
                <h2 class="mb-2 theme-text-main">@Html.DisplayFor(model => model.Dispositivo.Nombre)</h2>
                <div class="profile-status text-muted">
                    Información detallada del dispositivo
                </div>
            </div>
        </div>
    </div>

    <!-- Detalles -->
    <div class="form-container mt-4">
        <div class="form-header">
            <h3><i class="fas fa-info-circle me-2"></i>Detalles del Dispositivo</h3>
        </div>
        
        <div class="glass-card-inner p-4 mt-3">
            <div class="info-grid text-start">
                <div class="row w-100 m-0">
                    <div class="col-md-6 mb-3">
                        <strong class="d-block theme-text-main"><i class="fas fa-tag me-1"></i>Nombre</strong>
                        <span class="theme-text-main">@Html.DisplayFor(model => model.Dispositivo.Nombre)</span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <strong class="d-block theme-text-main"><i class="fas fa-list me-1"></i>Tipo</strong>
                        <span class="theme-text-main">@Html.DisplayFor(model => model.Dispositivo.Tipo)</span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <strong class="d-block theme-text-main"><i class="fas fa-tasks me-1"></i>Usos</strong>
                        <span class="theme-text-main">@Html.DisplayFor(model => model.Dispositivo.Usos)</span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <strong class="d-block theme-text-main"><i class="fas fa-industry me-1"></i>Marca</strong>
                        <span class="theme-text-main">@Html.DisplayFor(model => model.Dispositivo.Marca)</span>
                    </div>
                    <div class="col-12 mb-3">
                        <strong class="d-block theme-text-main"><i class="fas fa-check-circle me-1"></i>Estado</strong>
                        <span class="theme-text-main">@Html.DisplayFor(model => model.Dispositivo.Estado)</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-5">
            <a asp-page="./Index" class="btn-secondary-custom">
                <i class="fas fa-arrow-left me-2"></i>Volver a la lista
            </a>
            <a asp-page="./Edit" asp-route-id="@Model.Dispositivo.Id" class="btn-primary-custom">
                <i class="fas fa-edit me-2"></i>Editar Dispositivo
            </a>
        </div>
    </div>
</div>
