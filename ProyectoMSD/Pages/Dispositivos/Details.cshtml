@page
@model ProyectoMSD.Pages.Dispositivos.DetailsModel

@{
    ViewData["Title"] = "Detalles del Dispositivo";
    var estado = Model.Dispositivo?.Estado?.ToLower() ?? "";
    var badgeClass = (estado.Contains("activo") || estado.Contains("encendido"))
                     ? "bg-success" : "bg-secondary";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/propiedades.css" />
    <link href="~/css/pages/dispositivos.css" rel="stylesheet" />
}

<!-- HEADER BANNER -->
<div class="prop-page-header mb-4 mt-3">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div class="d-flex align-items-center gap-3">
            <div class="prop-header-icon">
                <i class="fas fa-microchip"></i>
            </div>
            <div>
                <h1 class="fw-bold mb-0" style="font-size:1.9rem;">@Model.Dispositivo!.Nombre</h1>
                <p class="mb-0 opacity-75" style="font-size:0.95rem;">
                    <i class="fas fa-satellite-dish me-1"></i>Monitorización IoT
                </p>
            </div>
        </div>
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <span class="prop-tipo-badge @badgeClass shadow-sm text-white px-3 py-1 rounded-pill fw-bold">
                <i class="fas fa-power-off me-1"></i>@Model.Dispositivo.Estado
            </span>
            <a asp-page="./Edit" asp-route-id="@Model.Dispositivo.Id" class="btn-primary-custom">
                <i class="fas fa-edit me-1"></i>Editar
            </a>
            <a asp-page="./Index" class="btn-secondary-custom">
                <i class="fas fa-arrow-left me-1"></i>Volver
            </a>
        </div>
    </div>
</div>

<!-- CONTENIDO PRINCIPAL -->
<div class="row g-4 mb-4">

    <!-- Panel: Información Técnica -->
    <div class="col-md-6">
        <div class="prop-detail-panel h-100">
            <div class="prop-detail-panel-header">
                <i class="fas fa-info-circle me-2"></i>Información Técnica
            </div>
            <div class="prop-detail-panel-body">
                <div class="prop-detail-row">
                    <div class="prop-detail-icon-box prop-icon-blue"><i class="fas fa-tag"></i></div>
                    <div>
                        <small class="prop-detail-label">Tipo de Dispositivo</small>
                        <div class="prop-detail-value">@Model.Dispositivo.Tipo</div>
                    </div>
                </div>
                <div class="prop-detail-row">
                    <div class="prop-detail-icon-box prop-icon-purple"><i class="fas fa-industry"></i></div>
                    <div>
                        <small class="prop-detail-label">Marca Comercial</small>
                        <div class="prop-detail-value">@Model.Dispositivo.Marca</div>
                    </div>
                </div>
                <div class="prop-detail-row">
                    <div class="prop-detail-icon-box prop-icon-cyan"><i class="fas fa-fingerprint"></i></div>
                    <div>
                        <small class="prop-detail-label">MAC Address</small>
                        <div class="prop-detail-value" style="font-family:monospace;">@Model.Dispositivo.MAC_Address</div>
                    </div>
                </div>
                <div class="prop-detail-row">
                    <div class="prop-detail-icon-box prop-icon-cyan"><i class="fas fa-tasks"></i></div>
                    <div>
                        <small class="prop-detail-label">Usos / Propósito</small>
                        <div class="prop-detail-value">@Model.Dispositivo.Usos</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Panel: Telemetría en Tiempo Real -->
    <div class="col-md-6">
        <div class="prop-detail-panel h-100">
            <div class="prop-detail-panel-header prop-header-green">
                <i class="fas fa-wifi me-2"></i>Telemetría en Tiempo Real
            </div>
            <div class="prop-detail-panel-body">
                <div class="d-flex flex-column gap-3 justify-content-center">
                    <div class="prop-detail-row d-flex flex-column align-items-center mb-0"
                         style="background:rgba(46,204,113,0.05);padding:1.5rem;border:1px solid rgba(46,204,113,0.2);">
                        <i class="fas fa-thermometer-half fa-2x text-success mb-2"></i>
                        <small class="prop-detail-label text-success fw-bold text-uppercase">Temperatura</small>
                        <h2 class="prop-detail-value mt-2 fw-bolder text-success" id="mqtt-temperatura">-- °C</h2>
                    </div>
                    <div class="prop-detail-row d-flex flex-column align-items-center mb-0"
                         style="background:rgba(52,152,219,0.05);padding:1.5rem;border:1px solid rgba(52,152,219,0.2);">
                        <i class="fas fa-tint fa-2x text-info mb-2"></i>
                        <small class="prop-detail-label text-info fw-bold text-uppercase">Humedad</small>
                        <h2 class="prop-detail-value mt-2 fw-bolder text-info" id="mqtt-humedad">-- %</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Panel: Control de Componentes (Dinámico) -->
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="prop-detail-panel">
            <div class="prop-detail-panel-header" style="background:linear-gradient(135deg,#667eea,#764ba2);">
                <i class="fas fa-sliders-h me-2"></i>Panel de Control
            </div>
            <div class="prop-detail-panel-body">

                @*
                    data-mac y data-nombre se inyectan desde el modelo Razor.
                    El JavaScript NUNCA tiene la MAC hardcodeada.
                *@
                <div id="dispositivo-control"
                     data-mac="@Model.Dispositivo.MAC_Address"
                     data-nombre="@Model.Dispositivo.Nombre">

                    @if (Model.Componentes.Any())
                    {
                        <div class="row g-3">
                            @foreach (var comp in Model.Componentes)
                            {
                                <div class="col-md-4">
                                    <div class="prop-detail-panel" style="border:1px solid rgba(255,255,255,0.1);">
                                        <div class="prop-detail-panel-header" style="padding:0.75rem 1rem;font-size:0.9rem;">
                                            <i class="@comp.Icono me-2"></i>@comp.Etiqueta
                                        </div>
                                        <div class="prop-detail-panel-body p-3">
                                            <div class="d-flex flex-wrap gap-2 justify-content-center">
                                                @foreach (var cmd in comp.Comandos)
                                                {
                                                    var btnClass = cmd.ToLower() switch
                                                    {
                                                        "encender" or "on" or "subir"  => "btn-success",
                                                        "apagar"   or "off" or "bajar" => "btn-danger",
                                                        _                               => "btn-secondary"
                                                    };
                                                    <button class="btn @btnClass btn-comando rounded-pill px-3 py-2"
                                                            data-componente="@comp.NombreInterno"
                                                            data-comando="@cmd">
                                                        @cmd
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="fas fa-plug fa-2x mb-2 d-block opacity-50"></i>
                            <p class="mb-0">Este dispositivo no tiene componentes configurados.</p>
                            <small>Edita el dispositivo para definir sus componentes controlables.</small>
                        </div>
                    }
                </div>

                <!-- Indicador de estado de comando -->
                <div id="comando-status" class="mt-3 text-center" style="display:none;">
                    <span class="badge bg-info px-3 py-2" id="status-text"></span>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        // ============================================================
        //  SIGNALR — Telemetría en tiempo real
        // ============================================================
        const hubConnection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/dispositivos")
            .withAutomaticReconnect()
            .build();

        hubConnection.on("ReceiveTelemetry", function (topic, payload) {
            try {
                const data = JSON.parse(payload);
                if (data.temp        !== undefined) document.getElementById("mqtt-temperatura").innerText = data.temp        + " °C";
                else if (data.temperatura !== undefined) document.getElementById("mqtt-temperatura").innerText = data.temperatura + " °C";
                if (data.humidity    !== undefined) document.getElementById("mqtt-humedad").innerText    = data.humidity    + " %";
                else if (data.humedad    !== undefined) document.getElementById("mqtt-humedad").innerText    = data.humedad    + " %";
            } catch (e) {
                console.warn("Payload MQTT no es JSON válido:", payload);
            }
        });

        hubConnection.start()
            .then(() => console.log("SignalR conectado al Hub de Dispositivos"))
            .catch(err => console.error("Error SignalR:", err));

        // ============================================================
        //  CONTROL DE COMPONENTES — Sin MAC ni topicos hardcodeados
        // ============================================================
        const controlPanel = document.getElementById("dispositivo-control");
        const mac          = controlPanel ? controlPanel.dataset.mac : "";

        document.querySelectorAll(".btn-comando").forEach(function(btn) {
            btn.addEventListener("click", async function() {
                const componente = btn.dataset.componente;
                const comando    = btn.dataset.comando;

                // Feedback visual al usuario
                const original  = btn.innerHTML;
                btn.innerHTML   = '<i class="fas fa-spinner fa-spin"></i>';
                btn.disabled    = true;
                mostrarStatus("Enviando comando...", "info");

                try {
                    const response = await fetch("/api/MqttComandos/comando", {
                        method:  "POST",
                        headers: { "Content-Type": "application/json" },
                        body:    JSON.stringify({
                            macDestino: mac,
                            componente: componente,
                            comando:    comando
                        })
                    });

                    const result = await response.json();
                    if (result.success) {
                        mostrarStatus("Comando enviado correctamente", "success");
                    } else {
                        mostrarStatus("Error: " + result.message, "danger");
                    }
                } catch (err) {
                    console.error("Error al enviar comando:", err);
                    mostrarStatus("Error de comunicacion con el servidor", "danger");
                } finally {
                    btn.innerHTML = original;
                    btn.disabled  = false;
                }
            });
        });

        function mostrarStatus(mensaje, tipo) {
            const statusDiv  = document.getElementById("comando-status");
            const statusText = document.getElementById("status-text");
            statusText.className = "badge bg-" + tipo + " px-3 py-2";
            statusText.innerText = mensaje;
            statusDiv.style.display = "block";
            setTimeout(() => { statusDiv.style.display = "none"; }, 3000);
        }
    </script>
}
