@page
@model ProyectoMSD.Pages.Dispositivos.EditModel

@{
    ViewData["Title"] = "Editar Dispositivo";
}

@section Styles {
    <link href="~/css/pages/dispositivos.css" rel="stylesheet" />
}

<div class="main-container">
    <!-- Device Header -->
    <div class="device-header">
        <div class="d-flex align-items-center">
            <div class="device-icon-container me-4">
                <div class="device-icon">
                    <i class="fas fa-mobile-alt"></i>
                </div>
                <div class="edit-badge">EDITAR</div>
            </div>
            <div class="device-info flex-grow-1">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h2 class="mb-2" id="header-nombre">@(Model.Dispositivo?.Nombre ?? "Dispositivo")</h2>
                        <div class="device-status">
                            En progreso: Editando información del dispositivo
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Info Cards -->
    <div class="info-cards">
        <div class="info-card">
            <div class="info-card-icon">
                <i class="fas fa-tag"></i>
            </div>
            <div class="info-card-value" id="card-nombre">@(Model.Dispositivo?.Nombre ?? "N/A")</div>
            <div class="info-card-label">Nombre Actual</div>
        </div>
        <div class="info-card">
            <div class="info-card-icon">
                <i class="fas fa-list"></i>
            </div>
            <div class="info-card-value" id="card-tipo">@(Model.Dispositivo?.Tipo ?? "N/A")</div>
            <div class="info-card-label">Tipo</div>
        </div>
        <div class="info-card">
            <div class="info-card-icon">
                <i class="fas fa-industry"></i>
            </div>
            <div class="info-card-value" id="card-marca">@(Model.Dispositivo?.Marca ?? "N/A")</div>
            <div class="info-card-label">Marca</div>
        </div>
        <div class="info-card">
            <div class="info-card-icon">
                <i class="fas fa-network-wired"></i>
            </div>
            <div class="info-card-value" id="card-mac">@(Model.Dispositivo?.MAC_Address ?? "N/A")</div>
            <div class="info-card-label">MAC Address</div>
        </div>
        <div class="info-card">
            <div class="info-card-icon">
                <i class="fas fa-check-circle"></i>
            </div>
            <div class="info-card-value" id="card-estado">@(Model.Dispositivo?.Estado ?? "N/A")</div>
            <div class="info-card-label">Estado</div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="content-wrapper">
        <!-- Form Section -->
        <div class="form-container">
            <div class="form-header">
                <h3>
                    <i class="fas fa-edit"></i>
                    Información del Dispositivo
                </h3>
                <p>Actualiza los datos del dispositivo en el sistema</p>
            </div>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <input type="hidden" asp-for="Dispositivo.Id" />

                <div class="form-grid">

                    <!-- Espacio -->
                    <div class="form-group form-grid-full">
                        <label class="form-label">
                            <i class="fas fa-door-open me-1 text-primary"></i>Espacio Asignado
                        </label>
                        <select asp-for="Dispositivo.IdEspacio" class="form-select" asp-items="ViewBag.IdEspacio">
                            <option value="">-- Seleccione un espacio --</option>
                        </select>
                        <span asp-validation-for="Dispositivo.IdEspacio" class="text-danger"></span>
                    </div>

                    <!-- Nombre -->
                    <div class="form-group form-grid-full">
                        <label class="form-label">
                            <i class="fas fa-tag me-1 text-primary"></i>Nombre del Dispositivo
                        </label>
                        <input asp-for="Dispositivo.Nombre" id="input-nombre" class="form-control" placeholder="Ingresa el nombre del dispositivo" />
                        <span asp-validation-for="Dispositivo.Nombre" class="text-danger"></span>
                    </div>

                    <!-- MAC Address -->
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-network-wired me-1 text-primary"></i>Dirección MAC
                        </label>
                        <input asp-for="Dispositivo.MAC_Address" id="input-mac" class="form-control" placeholder="Ej: 00:1A:2B:3C:4D:5E" />
                        <span asp-validation-for="Dispositivo.MAC_Address" class="text-danger"></span>
                    </div>

                    <!-- Protocolo -->
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-wifi me-1 text-primary"></i>Protocolo IoT
                        </label>
                        <input asp-for="Dispositivo.Protocolo" class="form-control" placeholder="Ej: MQTT, HTTP, Zigbee" />
                        <span asp-validation-for="Dispositivo.Protocolo" class="text-danger"></span>
                    </div>

                    <!-- Tipo -->
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-list me-1 text-primary"></i>Tipo de Dispositivo
                        </label>
                        <input asp-for="Dispositivo.Tipo" id="input-tipo" class="form-control" placeholder="Ej: Sensor, Actuador" />
                        <span asp-validation-for="Dispositivo.Tipo" class="text-danger"></span>
                    </div>

                    <!-- Marca -->
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-industry me-1 text-primary"></i>Marca
                        </label>
                        <input asp-for="Dispositivo.Marca" id="input-marca" class="form-control" placeholder="Ej: Tuya, Sonoff, Espressif" />
                        <span asp-validation-for="Dispositivo.Marca" class="text-danger"></span>
                    </div>

                    <!-- Usos -->
                    <div class="form-group form-grid-full">
                        <label class="form-label">
                            <i class="fas fa-tasks me-1 text-primary"></i>Usos del Dispositivo
                        </label>
                        <input asp-for="Dispositivo.Usos" class="form-control" placeholder="Ej: Medir temperatura ambiente" />
                        <span asp-validation-for="Dispositivo.Usos" class="text-danger"></span>
                    </div>

                    <!-- Estado -->
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-power-off me-1 text-primary"></i>Estado
                        </label>
                        <select asp-for="Dispositivo.Estado" id="input-estado" class="form-select">
                            <option value="Apagado">Apagado</option>
                            <option value="Encendido">Encendido</option>
                            <option value="Mantenimiento">En Mantenimiento</option>
                        </select>
                        <span asp-validation-for="Dispositivo.Estado" class="text-danger"></span>
                    </div>

                </div>

                <!-- EDITOR VISUAL DE COMPONENTES -->
                <div class="mb-4 mt-4 p-4 rounded" style="background: rgba(0, 0, 0, 0.2); border: 1px solid rgba(255,255,255,0.1);">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h5 class="fw-bold mb-1"><i class="fas fa-puzzle-piece me-2 text-primary"></i>Componentes Controlables</h5>
                            <p class="text-muted small mb-0">Define qué partes de este dispositivo pueden recibir comandos MQTT.</p>
                        </div>
                        <button type="button" class="btn btn-outline-info btn-sm rounded-pill" onclick="addComponente()">
                            <i class="fas fa-plus me-1"></i>Añadir Componente
                        </button>
                    </div>
                    
                    <input type="hidden" asp-for="Dispositivo.ComponentesJson" id="ComponentesJson" />
                    
                    <div id="components-container" class="row g-3">
                        <!-- Aquí se renderizan los componentes en JS -->
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-4">
                    <a asp-page="./Index" class="btn-secondary-custom">
                        <i class="fas fa-arrow-left me-2"></i>Volver a la lista
                    </a>
                    <button type="submit" class="btn-primary-custom">
                        <i class="fas fa-save me-2"></i>Guardar Cambios
                    </button>
                </div>
            </form>
        </div>

        <!-- Activity Sidebar -->
        <div class="activity-sidebar">
            <div class="activity-header">Actividad Reciente</div>

            <div class="activity-item">
                <div class="activity-status">En progreso</div>
                <div class="activity-title">Editando dispositivo</div>
                <a href="#" class="activity-action">Ver detalles</a>
            </div>

            <div class="activity-item">
                <div class="activity-status">Hace 20 minutos</div>
                <div class="activity-title">Dispositivo actualizado</div>
                <div class="activity-action">Sistema</div>
            </div>

            <div class="activity-item">
                <div class="activity-status">Hace 2 horas</div>
                <div class="activity-title">Estado modificado</div>
                <div class="activity-action">Configuración</div>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('input-nombre')?.addEventListener('input', function () {
        const card = document.getElementById('card-nombre');
        const header = document.getElementById('header-nombre');
        if (card) card.textContent = this.value || 'N/A';
        if (header) header.textContent = this.value || 'Dispositivo';
    });

    document.getElementById('input-tipo')?.addEventListener('input', function () {
        const card = document.getElementById('card-tipo');
        if (card) card.textContent = this.value || 'N/A';
    });

    document.getElementById('input-marca')?.addEventListener('input', function () {
        const card = document.getElementById('card-marca');
        if (card) card.textContent = this.value || 'N/A';
    });

    document.getElementById('input-mac')?.addEventListener('input', function () {
        const card = document.getElementById('card-mac');
        if (card) card.textContent = this.value || 'N/A';
    });

    document.getElementById('input-estado')?.addEventListener('change', function () {
        const card = document.getElementById('card-estado');
        if (card) card.textContent = this.value || 'N/A';
    });
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // ==========================================
        //  UI COMPONENT BUILDER (JSON Generator)
        // ==========================================
        let componentes = [];

        function addComponente() {
            componentes.push({
                nombreInterno: `comp_${Date.now()}`,
                etiqueta: "Nuevo Componente",
                icono: "fas fa-microchip",
                comandos: []
            });
            render();
        }

        function updateComponente(index, field, value) {
            componentes[index][field] = value;
            syncHidden();
        }

        function removeComponente(index) {
            componentes.splice(index, 1);
            render();
        }

        function addComando(compIndex) {
            const cmd = prompt("Ingresa el comando (ej: encender, off, subir_volumen):");
            if (cmd && cmd.trim() !== "") {
                componentes[compIndex].comandos.push(cmd.trim().toLowerCase());
                render();
            }
        }

        function removeComando(compIndex, cmdIndex) {
            componentes[compIndex].comandos.splice(cmdIndex, 1);
            render();
        }

        function syncHidden() {
            const hiddenInput = document.getElementById("ComponentesJson");
            hiddenInput.value = componentes.length > 0 ? JSON.stringify(componentes) : "";
        }

        function render() {
            const container = document.getElementById("components-container");
            container.innerHTML = "";

            if (componentes.length === 0) {
                container.innerHTML = '<div class="col-12 text-center text-muted py-3">No hay componentes configurados.</div>';
            }

            componentes.forEach((comp, idx) => {
                const html = `
                    <div class="col-md-6 mb-3">
                        <div class="card bg-dark text-white shadow-sm border-secondary h-100">
                            <div class="card-header bg-secondary bg-opacity-25 d-flex justify-content-between align-items-center py-2">
                                <div><i class="${comp.icono} me-2 text-info"></i><span class="fw-bold">${comp.etiqueta}</span></div>
                                <button type="button" class="btn btn-sm btn-outline-danger border-0" onclick="removeComponente(${idx})"><i class="fas fa-times"></i></button>
                            </div>
                            <div class="card-body p-3">
                                <div class="mb-2">
                                    <label class="form-label small text-muted mb-1">Nombre Visual (Etiqueta)</label>
                                    <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary" value="${comp.etiqueta}" onchange="updateComponente(${idx}, 'etiqueta', this.value); render();">
                                </div>
                                <div class="mb-2">
                                    <label class="form-label small text-muted mb-1">Nombre Interno (Clave MQTT)</label>
                                    <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary" value="${comp.nombreInterno}" onchange="updateComponente(${idx}, 'nombreInterno', this.value)">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label small text-muted mb-1">Clase Icono (FontAwesome)</label>
                                    <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary" value="${comp.icono}" onchange="updateComponente(${idx}, 'icono', this.value); render();">
                                </div>
                                <div class="border-top border-secondary pt-2 mt-2">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <small class="text-info fw-bold">Comandos</small>
                                        <button type="button" class="btn btn-sm btn-outline-success border-0 py-0" onclick="addComando(${idx})"><i class="fas fa-plus"></i></button>
                                    </div>
                                    <div class="d-flex flex-wrap gap-1">
                                        ${comp.comandos.length === 0 ? '<small class="text-muted fst-italic">Sin comandos</small>' : ''}
                                        ${comp.comandos.map((c, cIdx) => `
                                            <span class="badge bg-secondary d-flex align-items-center gap-1">
                                                ${c} <i class="fas fa-times text-danger" style="cursor:pointer;" onclick="removeComando(${idx}, ${cIdx})"></i>
                                            </span>
                                        `).join('')}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
                container.insertAdjacentHTML('beforeend', html);
            });
            syncHidden();
        }

        document.addEventListener('DOMContentLoaded', function() {
            // Inicializar parseando el JSON existente
            const hiddenInput = document.getElementById("ComponentesJson");
            if (hiddenInput.value && hiddenInput.value.trim() !== "") {
                try {
                    componentes = JSON.parse(hiddenInput.value);
                } catch (e) {
                    console.error("Error parseando ComponentesJson", e);
                    componentes = [];
                }
            }
            render();
        });
    </script>
}
