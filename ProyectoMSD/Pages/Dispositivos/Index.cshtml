@page
@model ProyectoMSD.Pages.Dispositivos.IndexModel

@{
    ViewData["Title"] = "Dispositivos";
}

@section Styles {
    <link href="~/css/pages/dispositivos.css" rel="stylesheet" />
}

<div class="container-fluid px-4 py-4">

    <!-- Header de Dispositivos -->
    <div class="devices-header text-center mb-4">
        <h1 class="display-4 fw-bold mb-3 text-main">
            <i class="fas fa-microchip me-3 text-primary-custom"></i>Lista de Dispositivos
        </h1>
        <p class="lead mb-0 text-muted">Control y administración de todos los dispositivos inteligentes</p>
    </div>

    <!-- Estadísticas Rápidas -->
    <div class="row pe-0 ps-0 mb-4 dispositivos-stats">
        <div class="col-md-3 mb-3">
            <div class="stats-card glass-card">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h3 class="fw-bold text-success m-0">@Model.DispositivosDto.Count()</h3>
                        <p class="text-muted mb-0 small text-uppercase">Total Dispositivos</p>
                    </div>
                    <i class="fas fa-microchip fa-2x text-success opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stats-card glass-card">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h3 class="fw-bold text-success m-0">
                            @Model.DispositivosDto.Count(d => d.IsActive)
                        </h3>
                        <p class="text-muted mb-0 small text-uppercase">Activos</p>
                    </div>
                    <i class="fas fa-power-off fa-2x text-success opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stats-card glass-card">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h3 class="fw-bold text-primary-custom m-0">@Model.DispositivosDto.GroupBy(d => d.Tipo).Count()</h3>
                        <p class="text-muted mb-0 small text-uppercase">Tipos Diferentes</p>
                    </div>
                    <i class="fas fa-layer-group fa-2x text-primary-custom opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stats-card glass-card">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h3 class="fw-bold text-warning m-0">@Model.DispositivosDto.GroupBy(d => d.Marca).Count()</h3>
                        <p class="text-muted mb-0 small text-uppercase">Marcas</p>
                    </div>
                    <i class="fas fa-tags fa-2x text-warning opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de Dispositivos -->
    <div class="devices-table-container glass-card mb-4 p-0 overflow-hidden">
        <div class="table-header p-4 border-bottom border-color-custom">
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0 fw-bold text-main h5">
                    <i class="fas fa-list me-2"></i>Catálogo de Dispositivos
                </h3>
                <span class="badge bg-primary-custom fs-6 px-3 py-2">@Model.DispositivosDto.Count() registrados</span>
            </div>
        </div>

        @if (Model.DispositivosDto != null && Model.DispositivosDto.Any())
        {
            <div class="table-responsive">
                <table class="table custom-table mb-0 align-middle">
                    <thead class="bg-card-item text-muted">
                        <tr>
                            <th class="ps-4 fw-medium border-color-custom py-3">ID</th>
                            <th class="fw-medium border-color-custom py-3">Tipo</th>
                            <th class="fw-medium border-color-custom py-3">Nombre</th>
                            <th class="fw-medium border-color-custom py-3 text-center">Estado</th>
                            <th class="fw-medium border-color-custom py-3">Marca / Usos</th>
                            <th class="pe-4 fw-medium border-color-custom py-3 text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.DispositivosDto)
                        {
                            <tr class="table-row-hover">
                                <td class="ps-4 border-color-custom text-muted small">
                                    #@item.Id
                                </td>
                                <td class="border-color-custom">
                                    <span class="badge-device @item.BadgeClass">
                                        <i class="@item.IconClass me-1"></i>
                                        @item.Tipo
                                    </span>
                                </td>
                                <td class="border-color-custom">
                                    <div class="fw-bold text-main">@item.Nombre</div>
                                </td>
                                <td class="border-color-custom text-center">
                                    <div class="d-flex align-items-center justify-content-center">
                                        <form method="post" asp-page-handler="ToggleEstado" class="m-0 p-0">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-link p-0 border-0 me-2 status-btn" title="Alternar Estado">
                                                <div class="status-toggle @(item.IsActive ? "active" : "")"></div>
                                            </button>
                                        </form>
                                        <span class="badge @(item.IsActive ? "bg-success" : "bg-danger bg-opacity-75") fs-7">
                                            @item.Estado.ToUpper()
                                        </span>
                                    </div>
                                </td>
                                <td class="border-color-custom text-muted small">
                                    <div class="d-flex flex-column">
                                        <span class="fw-semibold text-main mb-1"><i class="fas fa-industry me-1 opacity-50"></i>@item.Marca</span>
                                        <span class="fst-italic opacity-75">@item.Usos</span>
                                    </div>
                                </td>
                                <td class="pe-4 border-color-custom text-end">
                                    <div class="action-buttons d-inline-flex gap-2">
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-page="./Details" asp-route-id="@item.Id"
                                               class="btn btn-sm btn-outline-info" title="Ver detalles">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-page="./Edit" asp-route-id="@item.Id"
                                               class="btn btn-sm btn-outline-primary" title="Editar">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-page="./Delete" asp-route-id="@item.Id"
                                               class="btn btn-sm btn-outline-danger" title="Eliminar">
                                                <i class="fas fa-trash-alt"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-microchip fa-4x mb-4 text-muted opacity-25"></i>
                <h4 class="mb-3 text-main">No hay dispositivos registrados</h4>
                <p class="mb-4 text-muted">Comienza agregando tu primer dispositivo inteligente al sistema.</p>
                <a asp-page="Create" class="btn btn-primary-custom btn-lg">
                    <i class="fas fa-plus me-2"></i>Agregar Primer Dispositivo
                </a>
            </div>
        }
    </div>
</div>

<!-- Botón flotante para crear -->
<a asp-page="Create" class="create-button hover-lift" title="Agregar nuevo dispositivo">
    <i class="fas fa-plus"></i>
</a>