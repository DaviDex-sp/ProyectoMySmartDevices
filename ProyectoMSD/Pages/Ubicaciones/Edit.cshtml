@page
@model ProyectoMSD.Pages.Ubicaciones.EditModel

@{
    ViewData["Title"] = "Editar Ubicación";
}

@section Styles {
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <style>
        #map {
            height: 400px;
            width: 100%;
            border-radius: 15px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            margin-bottom: 20px;
        }
        .form-container {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        }
        .map-instructions {
            background-color: #e9ecef;
            border-left: 4px solid #0d6efd;
            padding: 15px;
            border-radius: 0 10px 10px 0;
            margin-bottom: 20px;
        }
    </style>
}

<div class="container mt-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-page="./Index" class="btn btn-outline-secondary me-3" style="border-radius: 50%; width: 40px; height: 40px; padding: 0; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-arrow-left"></i>
        </a>
        <h2 class="mb-0">
            <i class="fas fa-edit text-primary me-2"></i>Editar Ubicación
        </h2>
    </div>

    <div class="row">
        <div class="col-lg-7 mb-4">
            <!-- Map Section -->
            <div class="form-container h-100">
                <h4 class="mb-3">Mapa Interactivo</h4>
                <div class="map-instructions text-muted small">
                    <i class="fas fa-info-circle text-primary me-1"></i>
                    <strong>Haz clic</strong> en cualquier punto del mapa para cambiar la ubicación.
                </div>
                <div id="map"></div>
            </div>
        </div>
        
        <div class="col-lg-5 mb-4">
            <!-- Form Section -->
            <div class="form-container">
                <h4 class="mb-4">Modificar Datos</h4>
                <form method="post" id="ubicacionForm">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="Ubicacione.Id" />
                    
                    <div class="mb-3">
                        <label asp-for="Ubicacione.Latitud" class="form-label text-muted fw-bold">Latitud</label>
                        <input asp-for="Ubicacione.Latitud" class="form-control bg-light" id="latInput" readonly />
                        <span asp-validation-for="Ubicacione.Latitud" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Ubicacione.Longitud" class="form-label text-muted fw-bold">Longitud</label>
                        <input asp-for="Ubicacione.Longitud" class="form-control bg-light" id="lngInput" readonly />
                        <span asp-validation-for="Ubicacione.Longitud" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Ubicacione.DireccionFormateada" class="form-label text-muted fw-bold">Dirección</label>
                        <textarea asp-for="Ubicacione.DireccionFormateada" class="form-control" id="direccionInput" rows="3"></textarea>
                        <span asp-validation-for="Ubicacione.DireccionFormateada" class="text-danger"></span>
                        <div id="loadingAddress" class="form-text text-primary d-none">
                            <i class="fas fa-spinner fa-spin me-1"></i> Actualizando dirección...
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary w-100 py-2 d-flex align-items-center justify-content-center" style="border-radius: 10px;">
                                <i class="fas fa-save me-2"></i> Guardar Cambios
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Recuperar latitud y longitud inicial del modelo
            // ASP.NET Core reemplaza comas por puntos en front-end si cultura no es un problema estricto
            // Tratamos parsearlos seguros
            const initLatStr = "@Html.Raw(Model.Ubicacione?.Latitud.ToString(System.Globalization.CultureInfo.InvariantCulture))" || "4.6097";
            const initLngStr = "@Html.Raw(Model.Ubicacione?.Longitud.ToString(System.Globalization.CultureInfo.InvariantCulture))" || "-74.0817";
            
            const initialLat = parseFloat(initLatStr);
            const initialLng = parseFloat(initLngStr);
            
            const map = L.map('map').setView([initialLat, initialLng], 15);
            let currentMarker = L.marker([initialLat, initialLng]).addTo(map);

            // Layer OSM
            L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '&copy; OpenStreetMap'
            }).addTo(map);

            // Inputs DOM
            const latInput = document.getElementById('latInput');
            const lngInput = document.getElementById('lngInput');
            const direccionInput = document.getElementById('direccionInput');
            const loadingAddress = document.getElementById('loadingAddress');

            // Event Click
            map.on('click', function(e) {
                const lat = e.latlng.lat;
                const lng = e.latlng.lng;

                currentMarker.setLatLng(e.latlng);
                latInput.value = lat.toFixed(8).replace(',', '.');
                lngInput.value = lng.toFixed(8).replace(',', '.');

                obtenerDireccion(lat, lng);
            });

            async function obtenerDireccion(lat, lng) {
                loadingAddress.classList.remove('d-none');
                
                try {
                    const response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${lat}&lon=${lng}`);
                    const data = await response.json();

                    if (data && data.display_name) {
                        direccionInput.value = data.display_name;
                    }
                } catch (error) {
                    console.error("Geocoding err:", error);
                } finally {
                    loadingAddress.classList.add('d-none');
                }
            }
            
            setTimeout(() => { map.invalidateSize(); }, 300);
        });
    </script>
}
