@page
@model ProyectoMSD.Pages.Ubicaciones.DeleteModel

@{
    ViewData["Title"] = "Eliminar Ubicación";
}

<div class="container mt-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-page="./Index" class="btn btn-outline-secondary me-3 btn-circle-sm">
            <i class="fas fa-arrow-left"></i>
        </a>
        <h2 class="mb-0 text-danger">
            <i class="fas fa-trash-alt me-2"></i>Eliminar Ubicación
        </h2>
    </div>

    <div class="alert alert-danger shadow-sm mb-4 rounded-4 border-start border-5 border-danger">
        <div class="d-flex align-items-center"><i class="fas fa-exclamation-triangle me-2"></i>¿Estás seguro que deseas eliminar esta ubicación?</div>
        <p class="mb-0">Esta acción no se puede deshacer. Se requiere que ninguna propiedad o espacio dependa de esta ubicación antes de eliminarla.</p>
    </div>

    <div class="card shadow-sm border-0 form-container">
        <div class="card-body p-5">
            <h5 class="card-title text-muted mb-4 border-bottom pb-2">Datos de la Ubicación</h5>
            <dl class="row">
                <dt class="col-sm-3 text-muted">ID Sistema</dt>
                <dd class="col-sm-9 fw-bold">@Model.Ubicacione.Id</dd>

                <dt class="col-sm-3 text-muted">Latitud</dt>
                <dd class="col-sm-9">@Math.Round(Model.Ubicacione.Latitud, 6)</dd>

                <dt class="col-sm-3 text-muted">Longitud</dt>
                <dd class="col-sm-9">@Math.Round(Model.Ubicacione.Longitud, 6)</dd>

                <dt class="col-sm-3 text-muted">Dirección Validada</dt>
                <dd class="col-sm-9">
                    @(string.IsNullOrEmpty(Model.Ubicacione.DireccionFormateada) ? "Sin especificar" : Model.Ubicacione.DireccionFormateada)
                </dd>
            </dl>
            
            <div class="mt-4 pt-3 border-top">
                <form method="post">
                    <input type="hidden" asp-for="Ubicacione.Id" />
                    <button type="submit" class="btn btn-danger shadow-sm">
                        <i class="fas fa-trash-alt me-2"></i>Confirmar Eliminación
                    </button>
                    <a asp-page="./Index" class="btn btn-light border ms-2">Cancelar</a>
                </form>
            </div>
        </div>
    </div>
</div>
