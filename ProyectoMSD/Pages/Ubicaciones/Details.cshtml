@page
@model ProyectoMSD.Pages.Ubicaciones.DetailsModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    ViewData["Title"] = "Detalles de la Ubicación";
}

@section Styles {
    <!-- Google Maps Static Styles CSS -->
    <style>
        #staticMap {
            height: 300px;
            width: 100%;
            border-radius: 15px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }
        .details-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        }
    </style>
}

<div class="container mt-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-page="./Index" class="btn btn-outline-secondary me-3 btn-circle-sm">
            <i class="fas fa-arrow-left"></i>
        </a>
        <h2 class="mb-0">
            <i class="fas fa-info-circle text-info me-2"></i>Detalles de Ubicación
        </h2>
    </div>

    <div class="row">
        <div class="col-lg-5 mb-4">
            <div class="details-card h-100">
                <h4 class="mb-4 border-bottom pb-2">Información Resumen</h4>
                
                <dl class="row">
                    <dt class="col-sm-4 text-muted mt-2">ID Sistema</dt>
                    <dd class="col-sm-8 mt-2 fw-bold">@Model.Ubicacione.Id</dd>

                    <dt class="col-sm-4 text-muted mt-2">Latitud</dt>
                    <dd class="col-sm-8 mt-2">@Math.Round(Model.Ubicacione.Latitud, 6)</dd>

                    <dt class="col-sm-4 text-muted mt-2">Longitud</dt>
                    <dd class="col-sm-8 mt-2">@Math.Round(Model.Ubicacione.Longitud, 6)</dd>

                    <dt class="col-sm-4 text-muted mt-2">Dirección</dt>
                    <dd class="col-sm-8 mt-2">
                        @(string.IsNullOrEmpty(Model.Ubicacione.DireccionFormateada) ? "Sin especificar" : Model.Ubicacione.DireccionFormateada)
                    </dd>

                    <dt class="col-sm-4 text-muted mt-2">Fecha</dt>
                    <dd class="col-sm-8 mt-2">
                        @Model.Ubicacione.FechaCreacion?.ToString("dd/MM/yyyy HH:mm")
                    </dd>
                </dl>

                <div class="mt-4 pt-3 border-top d-flex gap-2">
                    <a asp-page="./Edit" asp-route-id="@Model.Ubicacione?.Id" class="btn btn-primary w-50">
                        <i class="fas fa-edit me-2"></i>Editar
                    </a>
                    <a asp-page="./Index" class="btn btn-light w-50 border">Volver</a>
                </div>
            </div>
        </div>
        
        <div class="col-lg-7 mb-4">
            <div class="details-card h-100 p-2">
                <div id="staticMap"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://maps.googleapis.com/maps/api/js?key=@Configuration["GoogleCloud:MapsApiKey"]"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const lat = parseFloat("@Html.Raw(Model.Ubicacione?.Latitud.ToString(System.Globalization.CultureInfo.InvariantCulture))") || 4.6097;
            const lng = parseFloat("@Html.Raw(Model.Ubicacione?.Longitud.ToString(System.Globalization.CultureInfo.InvariantCulture))") || -74.0817;
            
            const map = new google.maps.Map(document.getElementById('staticMap'), {
                center: { lat: lat, lng: lng },
                zoom: 16,
                disableDefaultUI: true,
                gestureHandling: 'none'
            });

            const marker = new google.maps.Marker({
                position: { lat: lat, lng: lng },
                map: map
            });

            const infoWindow = new google.maps.InfoWindow({
                content: "<b>Ubicación del Dispositivo/Espacio</b><br/>@Html.Raw(Model.Ubicacione?.DireccionFormateada?.Replace("\"", "\\\""))"
            });
            
            infoWindow.open(map, marker);
        });
    </script>
}
