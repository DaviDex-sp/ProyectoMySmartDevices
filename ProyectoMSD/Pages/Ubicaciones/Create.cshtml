@page
@model ProyectoMSD.Pages.Ubicaciones.CreateModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    ViewData["Title"] = "Crear Ubicación";
}

@section Styles {
    <!-- Google Maps styles usually don't need custom css, but keep the map height -->
    <style>
        #map {
            height: 400px;
            width: 100%;
            border-radius: 15px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            margin-bottom: 20px;
        }
        .form-container {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        }
        .map-instructions {
            background-color: #e9ecef;
            border-left: 4px solid #0d6efd;
            padding: 15px;
            border-radius: 0 10px 10px 0;
            margin-bottom: 20px;
        }
    </style>
}

<div class="container mt-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-page="Index" class="btn btn-outline-secondary me-3 btn-circle-sm">
            <i class="fas fa-arrow-left"></i>
        </a>
        <h2 class="mb-0">
            <i class="fas fa-map-pin text-primary me-2"></i>Nueva Ubicación
        </h2>
    </div>

    <div class="row">
        <div class="col-lg-7 mb-4">
            <!-- Map Section -->
            <div class="form-container h-100">
                <h4 class="mb-3">Selecciona en el Mapa</h4>
                <div class="map-instructions text-muted small">
                    <i class="fas fa-info-circle text-primary me-1"></i>
                    <strong>Haz clic</strong> en cualquier punto del mapa para fijar la ubicación. La dirección se intentará autocompletar.
                </div>
                <div id="map"></div>
            </div>
        </div>
        
        <div class="col-lg-5 mb-4">
            <!-- Form Section -->
            <div class="form-container">
                <h4 class="mb-4">Detalles</h4>
                <form method="post" id="ubicacionForm">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Ubicacione.Latitud" class="form-label text-muted fw-bold">Latitud</label>
                        <input asp-for="Ubicacione.Latitud" class="form-control bg-light" id="latInput" readonly />
                        <span asp-validation-for="Ubicacione.Latitud" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Ubicacione.Longitud" class="form-label text-muted fw-bold">Longitud</label>
                        <input asp-for="Ubicacione.Longitud" class="form-control bg-light" id="lngInput" readonly />
                        <span asp-validation-for="Ubicacione.Longitud" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Ubicacione.DireccionFormateada" class="form-label text-muted fw-bold">Dirección (Autocompletada)</label>
                        <div class="mb-3">
                            <input type="text" id="searchInput" class="form-control shadow-sm" placeholder="Escribe y elige tu ubicación de la lista..." />
                        </div>
                        <span asp-validation-for="Ubicacione.DireccionFormateada" class="text-danger"></span>
                        <div id="loadingAddress" class="form-text text-primary d-none mt-1">
                            <i class="fas fa-spinner fa-spin me-1"></i> Buscando dirección exacta...
                        </div>
                    </div>
                    <div class="mt-4">
                    <button type="submit" class="btn btn-primary w-100 py-2 d-flex align-items-center justify-content-center rounded-3" id="btnGuardar" disabled>
                        <i class="fas fa-save me-2"></i>Guardar Ubicación
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script src="https://maps.googleapis.com/maps/api/js?key=@Configuration["GoogleCloud:MapsApiKey"]&libraries=places"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const defaultLat = 4.6097;
            const defaultLng = -74.0817;
            
            const map = new google.maps.Map(document.getElementById('map'), {
                zoom: 12,
                center: { lat: defaultLat, lng: defaultLng },
                mapTypeControl: false,
                streetViewControl: false
            });

            // If we want it initially placed or only after click/search
            const currentMarker = new google.maps.Marker({
                position: { lat: defaultLat, lng: defaultLng },
                map: map,
                draggable: true
            });

            const latInput = document.getElementById('latInput');
            const lngInput = document.getElementById('lngInput');
            const direccionInput = document.getElementById('searchInput'); // was searchInput instead of direccionInput here? Wait, the HTML has id="searchInput"
            const loadingAddress = document.getElementById('loadingAddress');
            const btnGuardar = document.getElementById('btnGuardar');
            const geocoder = new google.maps.Geocoder();

            // Configurar Autocomplete nativo de Google Places
            const autocomplete = new google.maps.places.Autocomplete(direccionInput, {
                componentRestrictions: { country: ["co", "us"] },
                fields: ["geometry", "formatted_address"]
            });

            autocomplete.addListener("place_changed", () => {
                const place = autocomplete.getPlace();
                if (!place.geometry || !place.geometry.location) {
                    return; // Enter presionado sin preselección
                }
                
                loadingAddress.classList.add('d-none');
                map.setCenter(place.geometry.location);
                map.setZoom(16);
                currentMarker.setPosition(place.geometry.location);
                
                const lat = place.geometry.location.lat();
                const lng = place.geometry.location.lng();
                
                latInput.value = lat.toFixed(8).replace(',', '.');
                lngInput.value = lng.toFixed(8).replace(',', '.');
                direccionInput.value = place.formatted_address;
                btnGuardar.disabled = false;
            });



            direccionInput.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                }
            });

            map.addListener('click', function(e) {
                const lat = e.latLng.lat();
                const lng = e.latLng.lng();
                currentMarker.setPosition(e.latLng);
                latInput.value = lat.toFixed(8).replace(',', '.');
                lngInput.value = lng.toFixed(8).replace(',', '.');
                btnGuardar.disabled = false;
                obtenerDireccion(lat, lng);
            });
            
            currentMarker.addListener('dragend', function(e) {
                const lat = e.latLng.lat();
                const lng = e.latLng.lng();
                latInput.value = lat.toFixed(8).replace(',', '.');
                lngInput.value = lng.toFixed(8).replace(',', '.');
                btnGuardar.disabled = false;
                obtenerDireccion(lat, lng);
            });

            function obtenerDireccion(lat, lng) {
                loadingAddress.classList.remove('d-none');
                direccionInput.disabled = true;

                geocoder.geocode({ location: { lat: lat, lng: lng } }, function(results, status) {
                    loadingAddress.classList.add('d-none');
                    direccionInput.disabled = false;
                    if (status === 'OK' && results[0]) {
                        direccionInput.value = results[0].formatted_address;
                    } else {
                        direccionInput.value = "Dirección no encontrada (escribe manualmente)";
                    }
                });
            }
        });
    </script>
}
