@page
@model ProyectoMSD.Pages.Ubicaciones.CreateModel

@{
    ViewData["Title"] = "Crear Ubicación";
}

@section Styles {
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <style>
        #map {
            height: 400px;
            width: 100%;
            border-radius: 15px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            margin-bottom: 20px;
        }
        .form-container {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        }
        .map-instructions {
            background-color: #e9ecef;
            border-left: 4px solid #0d6efd;
            padding: 15px;
            border-radius: 0 10px 10px 0;
            margin-bottom: 20px;
        }
    </style>
}

<div class="container mt-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-page="Index" class="btn btn-outline-secondary me-3" style="border-radius: 50%; width: 40px; height: 40px; padding: 0; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-arrow-left"></i>
        </a>
        <h2 class="mb-0">
            <i class="fas fa-map-pin text-primary me-2"></i>Nueva Ubicación
        </h2>
    </div>

    <div class="row">
        <div class="col-lg-7 mb-4">
            <!-- Map Section -->
            <div class="form-container h-100">
                <h4 class="mb-3">Selecciona en el Mapa</h4>
                <div class="map-instructions text-muted small">
                    <i class="fas fa-info-circle text-primary me-1"></i>
                    <strong>Haz clic</strong> en cualquier punto del mapa para fijar la ubicación. La dirección se intentará autocompletar.
                </div>
                <div id="map"></div>
            </div>
        </div>
        
        <div class="col-lg-5 mb-4">
            <!-- Form Section -->
            <div class="form-container">
                <h4 class="mb-4">Detalles</h4>
                <form method="post" id="ubicacionForm">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Ubicacione.Latitud" class="form-label text-muted fw-bold">Latitud</label>
                        <input asp-for="Ubicacione.Latitud" class="form-control bg-light" id="latInput" readonly />
                        <span asp-validation-for="Ubicacione.Latitud" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Ubicacione.Longitud" class="form-label text-muted fw-bold">Longitud</label>
                        <input asp-for="Ubicacione.Longitud" class="form-control bg-light" id="lngInput" readonly />
                        <span asp-validation-for="Ubicacione.Longitud" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Ubicacione.DireccionFormateada" class="form-label text-muted fw-bold">Dirección (Autocompletada)</label>
                        <textarea asp-for="Ubicacione.DireccionFormateada" class="form-control" id="direccionInput" rows="3" placeholder="Haz clic en el mapa o escribe manualmente..."></textarea>
                        <span asp-validation-for="Ubicacione.DireccionFormateada" class="text-danger"></span>
                        <div id="loadingAddress" class="form-text text-primary d-none">
                            <i class="fas fa-spinner fa-spin me-1"></i> Buscando dirección...
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 d-flex align-items-center justify-content-center" style="border-radius: 10px;" id="btnGuardar" disabled>
                        <i class="fas fa-save me-2"></i> Guardar Ubicación
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Inicializar el mapa centrado en una ubicación por defecto (ej. Colombia/Bogotá)
            const defaultLat = 4.6097;
            const defaultLng = -74.0817;
            
            const map = L.map('map').setView([defaultLat, defaultLng], 12);
            let currentMarker = null;

            // Capa de tiles de OpenStreetMap
            L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '&copy; <a href="http://www.openstreetmap.org/copyright">OpenStreetMap</a>'
            }).addTo(map);

            // Intentar obtener la ubicación actual del usuario si el navegador lo permite
            map.locate({setView: true, maxZoom: 16});

            map.on('locationfound', function(e) {
                // No forzamos un marker aquí para que el usuario elija conscientemente,
                // solo centramos el mapa en su ciudad/zona.
            });

            // Referencias del formulario
            const latInput = document.getElementById('latInput');
            const lngInput = document.getElementById('lngInput');
            const direccionInput = document.getElementById('direccionInput');
            const loadingAddress = document.getElementById('loadingAddress');
            const btnGuardar = document.getElementById('btnGuardar');

            // Evento Click en el Mapa
            map.on('click', function(e) {
                const lat = e.latlng.lat;
                const lng = e.latlng.lng;

                // Actualizar marcador
                if (currentMarker) {
                    currentMarker.setLatLng(e.latlng);
                } else {
                    currentMarker = L.marker(e.latlng).addTo(map);
                }

                // Actualizar inputs numericos asegurando punto decimal para el servidor
                // C# MVC a veces tiene problemas con la cultura (coma vs punto). 
                // Convertiremos a string con punto para evitar validaciones locas de Razor.
                latInput.value = lat.toFixed(8).replace(',', '.');
                lngInput.value = lng.toFixed(8).replace(',', '.');

                // Habilitar botón de guardar
                btnGuardar.disabled = false;

                // Reverse Geocoding via Nominatim
                obtenerDireccion(lat, lng);
            });

            async function obtenerDireccion(lat, lng) {
                loadingAddress.classList.remove('d-none');
                direccionInput.disabled = true;

                try {
                    // API de Nominatim
                    const response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${lat}&lon=${lng}`);
                    const data = await response.json();

                    if (data && data.display_name) {
                        direccionInput.value = data.display_name;
                    } else {
                        direccionInput.value = "Dirección no encontrada (escribe manualmente)";
                    }
                } catch (error) {
                    console.error("Error al obtener la dirección:", error);
                    direccionInput.value = "Error al intentar buscar la dirección";
                } finally {
                    loadingAddress.classList.add('d-none');
                    direccionInput.disabled = false;
                }
            }
            
            // Fix para el renderizado del mapa cuando está dentro de modales o containers flexbox
            setTimeout(() => {
                map.invalidateSize();
            }, 300);
        });
    </script>
}
