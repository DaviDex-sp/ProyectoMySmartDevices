@page
@model ProyectoMSD.Pages.Ubicaciones.IndexModel

@{
    ViewData["Title"] = "Ubicaciones";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="fas fa-map-marked-alt text-primary me-2"></i>Gestión de Ubicaciones
        </h2>
        <a asp-page="Create" class="btn btn-primary shadow-sm rounded-pill">
            <i class="fas fa-plus-circle me-2"></i>Nueva Ubicación
        </a>
    </div>

    <div class="card shadow-sm border-0 form-container">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="glass-card-header text-primary">
                    <tr>
                        <th class="py-3">Dirección Guardada</th>
                        <th class="py-3">Coordenadas</th>
                        <th class="py-3 text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Ubicacion)
                    {
                        <tr>
                            <td class="align-middle">
                                <strong>@(string.IsNullOrEmpty(item.DireccionFormateada) ? "Sin dirección" : item.DireccionFormateada)</strong>
                            </td>
                            <td class="align-middle text-muted">
                                <small>
                                    <i class="fas fa-globe me-1"></i> @Math.Round(item.Latitud, 5), @Math.Round(item.Longitud, 5)
                                </small>
                            </td>
                            <td class="align-middle text-center">
                                <div class="btn-group" role="group">
                                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Editar">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Ver en Mapa">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Eliminar">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Ubicacion.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted">
                                <i class="fas fa-map-signs fa-3x mb-3 text-light"></i>
                                <p>No hay ubicaciones registradas en el sistema.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
