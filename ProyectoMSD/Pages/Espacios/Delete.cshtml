@page
@model ProyectoMSD.Pages.Espacios.DeleteModel

@{
    ViewData["Title"] = "Delete";
}

<div class="main-container" style="max-width: 900px;">
    <!-- Danger Header -->
    <div class="profile-header glass-card-header" style="border-bottom: 2px solid #dc3545;">
        <div class="d-flex align-items-center">
            <div class="position-relative me-4">
                <div class="device-icon" style="width:100px; height:100px; background:rgba(220,53,69,0.1); border:2px solid rgba(220,53,69,0.3); border-radius:20px; display:flex; align-items:center; justify-content:center; font-size:2.5rem; color:#dc3545;">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
            </div>
            <div class="flex-grow-1">
                <h2 class="mb-2 theme-text-main">¿Eliminar Espacio?</h2>
                <div class="profile-status text-danger">
                    <strong>¡ATENCIÓN!</strong> Esta acción no se puede deshacer
                </div>
            </div>
        </div>
    </div>

    <!-- Warning Section -->
    <div class="form-container" style="border: 1px solid rgba(220,53,69,0.2);">
        <div class="alert alert-danger" style="border-left: 4px solid #dc3545; background: rgba(220,53,69,0.05); color: var(--text-color);">
            <strong>¿Estás seguro de que quieres eliminar este espacio?</strong><br>
            Esta acción eliminará permanentemente la información del espacio.
        </div>

        <!-- Space Details -->
        <div class="glass-card-inner p-4 text-center mt-4">
            <div class="info-grid text-start">
                <div class="row w-100 m-0">
                    <div class="col-6 mb-3">
                        <strong class="d-block theme-text-main"><i class="fas fa-cube me-1"></i>Nombre</strong>
                        <span>@Html.DisplayFor(model => model.Espacio.Nombre)</span>
                    </div>
                    <div class="col-6 mb-3">
                        <strong class="d-block theme-text-main"><i class="fas fa-wifi me-1"></i>Señal</strong>
                        <span>@Html.DisplayFor(model => model.Espacio.Señal)%</span>
                    </div>
                    <div class="col-6 mb-3">
                        <strong class="d-block theme-text-main"><i class="fas fa-shield-alt me-1"></i>Permisos</strong>
                        <span>@Html.DisplayFor(model => model.Espacio.Permisos)</span>
                    </div>
                </div>
            </div>
        </div>

        <form method="post" class="mt-4">
            <input type="hidden" asp-for="Espacio.Id" />
            <div class="d-flex justify-content-between align-items-center">
                <a asp-page="./Index" class="btn-secondary-custom">
                    <i class="fas fa-arrow-left me-2"></i>Cancelar
                </a>
                <button type="submit" class="btn-danger-custom" onclick="return confirm('¿Estás completamente seguro? Esta acción no se puede deshacer.')">
                    <i class="fas fa-trash me-2"></i>Confirmar Eliminación
                </button>
            </div>
        </form>
    </div>
</div>
