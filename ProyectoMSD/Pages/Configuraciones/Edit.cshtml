@page
@model ProyectoMSD.Pages.Configuraciones.EditModel

@{
    ViewData["Title"] = "Editar Configuración";
}

@section Styles {
    <style>
        .edit-container {
            max-width: 800px;
            margin: 3rem auto;
        }
    </style>
}

<div class="container edit-container">
    <div class="form-container">
        <div class="form-header">
            <h3><i class="fas fa-edit me-2"></i>Editar Registro de Configuración</h3>
            <p>Modifica los parámetros técnicos de sincronización y alertas.</p>
        </div>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3"></div>
            <input type="hidden" asp-for="Configuracione.Codigo" />

            <div class="row g-4">
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="Configuracione.Idioma" class="form-label">Idioma de Interfaz</label>
                        <input asp-for="Configuracione.Idioma" class="form-control" placeholder="Ej: Español" />
                        <span asp-validation-for="Configuracione.Idioma" class="text-danger small"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="Configuracione.Alertas" class="form-label">Canales de Alerta</label>
                        <input asp-for="Configuracione.Alertas" class="form-control" placeholder="Ej: Email, Push" />
                        <span asp-validation-for="Configuracione.Alertas" class="text-danger small"></span>
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="form-group p-3 border rounded-3 bg-light bg-opacity-10">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" asp-for="Configuracione.Automatizacion">
                            <label class="form-check-label fw-bold" asp-for="Configuracione.Automatizacion">Activar Automatización Avanzada</label>
                            <small class="d-block text-muted">Permite que el sistema tome decisiones basadas en sensores (Escenas AI).</small>
                        </div>
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="form-group">
                        <label asp-for="Configuracione.Adaptador" class="form-label">Adaptador de Protocolo</label>
                        <input asp-for="Configuracione.Adaptador" class="form-control font-monospace" placeholder="Ej: MQTT, WebSocket" />
                        <span asp-validation-for="Configuracione.Adaptador" class="text-danger small"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="Configuracione.IdDispositivos" class="form-label">Dispositivo Vinculado</label>
                        <select asp-for="Configuracione.IdDispositivos" class="form-select" asp-items="ViewBag.IdDispositivos"></select>
                        <span asp-validation-for="Configuracione.IdDispositivos" class="text-danger small"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="Configuracione.IdUsuarios" class="form-label">Usuario Propietario</label>
                        <select asp-for="Configuracione.IdUsuarios" class="form-select" asp-items="ViewBag.IdUsuarios"></select>
                        <span asp-validation-for="Configuracione.IdUsuarios" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-5 pt-3 border-top">
                <a asp-page="./Index" class="btn btn-secondary-custom">
                    <i class="fas fa-arrow-left me-2"></i>Volver al Panel
                </a>
                <button type="submit" class="btn btn-primary-custom">
                    <i class="fas fa-save me-2"></i>Guardar Cambios
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
