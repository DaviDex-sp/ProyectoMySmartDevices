@page
@model ProyectoMSD.Pages.AccesoPendienteModel

@{
    ViewData["Title"] = "Acceso Pendiente";
    // We can hide the standard layout navbar if it shows options for logged users
    // But since they are not logged in, the Layout is probably appropriate.
    Layout = "_Layout";
}

<div class="main-container d-flex align-items-center justify-content-center min-vh-80">
    <div class="form-container text-center mw-100" style="max-width: 500px;">
        <div class="form-content p-5">
            <div class="mb-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto icon-container-lg bg-warning bg-opacity-10 text-warning">
                    <i class="fas fa-clock fa-3x"></i>
                </div>
            </div>
            <h2 class="fw-bold mb-3 theme-text-main">Cuenta en Verificación</h2>
            <p class="theme-text-main fs-5 mb-4">
                Su usuario está <strong>pendiente por activación</strong>. Deberá esperar a que un administrador complete el proceso de verificación para que pueda acceder al sistema.
            </p>
            <div class="mt-4">
                <a asp-page="/Login" class="btn btn-outline-primary rounded-pill px-4 py-2 fw-bold w-100">
                    <i class="fas fa-arrow-left me-2"></i>Volver al Inicio de Sesión
                </a>
            </div>
        </div>
    </div>
</div>
