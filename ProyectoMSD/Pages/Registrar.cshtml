@page
@model ProyectoMSD.Pages.RegistrarModel

@{
    ViewData["Title"] = "Registro - MySmartDevice";
    ViewData["ShowNavbar"] = false;
}

@section Styles {
    <link href="~/css/pages/registrar.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
}

<div class="container-fluid px-4 py-4">

    <div class="register-header text-center">
        <h1 class="display-4 fw-bold mb-3">
            <i class="fas fa-user-plus me-3 text-primary"></i>REGISTRO
        </h1>
        <p class="lead text-muted mb-0">Únete a la comunidad inteligente de MySmartDevice</p>
    </div>

    <div class="brand-section">
        <div class="brand-icon">
            <i class="fas fa-user-plus"></i>
        </div>
        <h2 class="brand-text">My<span class="smart">Smart</span>Device</h2>
        <p class="text-muted mt-2 mb-0">Crea tu cuenta y controla tu hogar inteligente</p>
    </div>

    <div class="form-section">
        <div class="form-header d-flex justify-content-between align-items-center">
            <div>
                <h4 class="mb-1 fw-bold">
                    <i class="fas fa-edit me-2"></i>Información de Registro
                </h4>
                <p class="text-muted mb-0">Completa todos los campos para crear tu cuenta</p>
            </div>
            <span class="badge content-badge">Nuevo Usuario</span>
        </div>

        <div class="form-body">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <form method="post">
                <div class="section-title">
                    <i class="fas fa-user me-2 text-primary"></i>Información Personal
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="Usuario.Nombre" class="form-control" placeholder="Nombre">
                            <label asp-for="Usuario.Nombre"><i class="fas fa-user me-2"></i>Nombre Completo</label>
                            <span asp-validation-for="Usuario.Nombre" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="Usuario.Correo" type="email" class="form-control" placeholder="Correo">
                            <label asp-for="Usuario.Correo"><i class="fas fa-envelope me-2"></i>Correo Electrónico</label>
                            <span asp-validation-for="Usuario.Correo" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <label class="form-label text-muted ms-1 mb-1" style="font-size: 0.85rem;"><i class="fas fa-phone me-1"></i>Teléfono Móvil</label>
                        <div class="input-group mb-3 custom-phone-group">
                            <select asp-for="Usuario.PrefijoTelefono" class="form-select mw-130 rounded-end-0">
                                <option value="+57">🇨🇴 +57</option>
                                <option value="+1">🇺🇸 +1</option>
                                <option value="+52">🇲🇽 +52</option>
                                <option value="+34">🇪🇸 +34</option>
                                <option value="+54">🇦🇷 +54</option>
                                <option value="+56">🇨🇱 +56</option>
                                <option value="+51">🇵🇪 +51</option>
                                <option value="+58">🇻🇪 +58</option>
                                <option value="+55">🇧🇷 +55</option>
                                <option value="+593">🇪🇨 +593</option>
                                <option value="+507">🇵🇦 +507</option>
                            </select>
                            <input asp-for="Usuario.Telefono" type="number" class="form-control rounded-start-0" placeholder="Número de celular">
                        </div>
                        <span asp-validation-for="Usuario.PrefijoTelefono" class="text-danger d-block"></span>
                        <span asp-validation-for="Usuario.Telefono" class="text-danger d-block"></span>
                    </div>
                </div>

                <div class="section-title">
                    <i class="fas fa-map-marked-alt me-2 text-primary"></i>Datos de Ubicación
                </div>

                <div class="row mb-3">
                    <div class="col-12">
                        <div class="alert glass-card-inner border border-primary-subtle theme-text-main small mb-3">
                            <i class="fas fa-info-circle me-1 text-primary"></i> Haz clic en el mapa interactivo para seleccionar la dirección exacta de tu residencia.
                        </div>
                        <div id="map" class="map-container-interactive"></div>
                        
                        <input type="hidden" asp-for="Latitud" id="latInput" />
                        <input type="hidden" asp-for="Longitud" id="lngInput" />

                        <div class="input-group mb-2">
                            <div class="form-floating flex-grow-1">
                                <input type="text" asp-for="DireccionFormateada" class="form-control border-end-0 shadow-none rounded-start-3" id="direccionInput" placeholder="Dirección" />
                                <label asp-for="DireccionFormateada"><i class="fas fa-map-pin me-2 text-primary"></i>Dirección (Por favor, agrega el número de tu casa)</label>
                            </div>
                            <button class="btn btn-primary px-4 d-flex align-items-center justify-content-center z-3 rounded-end-3" type="button" id="btnSearchUbicacion">
                                <i class="fas fa-search me-2"></i> Buscar
                            </button>
                        </div>
                        <div id="loadingAddress" class="form-text text-primary d-none mt-2">
                            <i class="fas fa-spinner fa-spin me-1"></i> Buscando dirección exacta...
                        </div>
                    </div>
                </div>

                <div class="section-title">
                    <i class="fas fa-id-card me-2 text-primary"></i>Documentación (Opcional)
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="Usuario.Documento" type="number" class="form-control" placeholder="Documento">
                            <label asp-for="Usuario.Documento"><i class="fas fa-id-card me-2"></i>Documento de Identidad</label>
                            <span asp-validation-for="Usuario.Documento" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="Usuario.Rut" class="form-control" placeholder="RUT (Opcional)">
                            <label asp-for="Usuario.Rut"><i class="fas fa-building me-2"></i>RUT (Opcional)</label>
                            <span asp-validation-for="Usuario.Rut" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="section-title">
                    <i class="fas fa-shield-alt me-2 text-primary"></i>Seguridad y Acceso
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="Usuario.Clave" type="password" class="form-control" placeholder="Contraseña">
                            <label asp-for="Usuario.Clave"><i class="fas fa-lock me-2"></i>Contraseña</label>
                            <span asp-validation-for="Usuario.Clave" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <select asp-for="Usuario.Rol" class="form-select">
                                <option value="">Seleccionar rol...</option>
                                <option value="Usuario">Usuario</option>
                                <option value="Huesped">Huésped</option>
                            </select>
                            <label asp-for="Usuario.Rol"><i class="fas fa-user-tag me-2"></i>Tipo de Usuario</label>
                            <span asp-validation-for="Usuario.Rol" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <input asp-for="Usuario.Permisos" type="hidden" value="limitado">
                <input asp-for="Usuario.Acesso" type="hidden" value="pendiente">

                <div class="alert alert-info d-flex align-items-center mt-4 glass-card-inner border border-primary border-opacity-25 rounded-3">
                    <i class="fas fa-info-circle me-2"></i>
                    <div>
                        <strong>Configuración automática:</strong> Tu cuenta será creada con <span class="badge bg-warning text-dark">Acceso Limitado</span> y estado <span class="badge bg-secondary">Pendiente de Activación</span>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-4">
                    <div>
                        <p class="text-muted mb-0">
                            ¿Ya tienes una cuenta?
                            <a href="/" class="login-link">Iniciar Sesión</a>
                        </p>
                    </div>
                    <button type="submit" class="btn btn-primary w-auto px-5 py-2">
                        <i class="fas fa-user-plus me-2"></i>Crear Cuenta
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Default Bogota
            const defaultLat = 4.6097;
            const defaultLng = -74.0817;
            const map = L.map('map').setView([defaultLat, defaultLng], 12);
            let currentMarker = null;

            L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '&copy; OpenStreetMap'
            }).addTo(map);

            map.locate({setView: true, maxZoom: 14});

            const latInput = document.getElementById('latInput');
            const lngInput = document.getElementById('lngInput');
            const direccionInput = document.getElementById('direccionInput');
            const loadingAddress = document.getElementById('loadingAddress');
            const btnSearch = document.getElementById('btnSearchUbicacion');

            // --- Geocoding con Input de Texto manual ---
            btnSearch.addEventListener('click', async function() {
                const query = direccionInput.value.trim();
                if (!query) return;

                loadingAddress.classList.remove('d-none');
                try {
                    // Limpiar la query de caracteres problemáticos para OSM en Latam (como el #)
                    let cleanQuery = query.replace(/#/g, '');
                    // Forzar búsqueda en Colombia para mayor exactitud
                    const url = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(cleanQuery)}&limit=1&countrycodes=co`;
                    
                    const response = await fetch(url);
                    const data = await response.json();
                    
                    if (data && data.length > 0) {
                        const result = data[0];
                        const lat = parseFloat(result.lat);
                        const lng = parseFloat(result.lon);
                        
                        map.setView([lat, lng], 16);
                        
                        if (currentMarker) {
                            currentMarker.setLatLng([lat, lng]);
                        } else {
                            currentMarker = L.marker([lat, lng]).addTo(map);
                        }
                        
                        latInput.value = lat.toFixed(8).replace(',', '.');
                        lngInput.value = lng.toFixed(8).replace(',', '.');
                        direccionInput.value = result.display_name;
                    } else {
                        // Si no lo encuentra, mostramos un aviso
                        alert("No se encontró la dirección exacta. Intente ser más específico (ej. agregando la ciudad).");
                    }
                } catch (error) {
                    console.error("Geocoding err:", error);
                } finally {
                    loadingAddress.classList.add('d-none');
                }
            });

            // Buscar al presionar Enter en el input de dirección
            direccionInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    btnSearch.click();
                }
            });

            // --- Evento Click Normal ---
            map.on('click', function(e) {
                const lat = e.latlng.lat;
                const lng = e.latlng.lng;

                if (currentMarker) {
                    currentMarker.setLatLng(e.latlng);
                } else {
                    currentMarker = L.marker(e.latlng).addTo(map);
                }

                latInput.value = lat.toFixed(8).replace(',', '.');
                lngInput.value = lng.toFixed(8).replace(',', '.');

                obtenerDireccion(lat, lng);
            });

            async function obtenerDireccion(lat, lng) {
                loadingAddress.classList.remove('d-none');
                try {
                    const response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${lat}&lon=${lng}`);
                    const data = await response.json();
                    
                    if (data && data.address) {
                        // Extraemos las partes útiles para direcciones en Colombia
                        let calle = data.address.road || '';
                        let barrio = data.address.neighbourhood || data.address.suburb || '';
                        let ciudad = data.address.city || data.address.town || '';
                        
                        // Armamos un formato limpio: "Calle 6D, Tintalá, Bogotá"
                        let direccionLimpia = [calle, barrio, ciudad].filter(Boolean).join(', ');
                        
                        // Si por algún motivo no hay calle, usamos el nombre general
                        if (!calle && data.display_name) {
                            direccionLimpia = data.display_name.split(',').slice(0, 3).join(', ');
                        }

                        direccionInput.value = direccionLimpia;
                        
                        // Hacemos que el input brille y tome el foco para que el usuario escriba su número
                        direccionInput.focus();
                        
                    } else {
                        direccionInput.value = "";
                    }
                } catch (error) {
                    console.error("Error al obtener dirección:", error);
                    direccionInput.value = "";
                } finally {
                    loadingAddress.classList.add('d-none');
                }
            }
            
            setTimeout(() => { map.invalidateSize(); }, 300);
        });
    </script>
}