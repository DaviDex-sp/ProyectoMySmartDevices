@page
@model ProyectoMSD.Pages.Soportes.DetailsModel

@{
    ViewData["Title"] = "Detalles del Soporte";
}

@section Styles {
    <link href="~/css/pages/soportes.css" rel="stylesheet" />
}

<div class="main-container max-w-900 mx-auto">
    <div class="form-container">
        <!-- Header -->
        <div class="text-center mb-4 pb-3 border-bottom">
            <div class="icon-container-lg mx-auto bg-primary text-white mb-3 shadow fs-1">
                <i class="fas fa-ticket-alt"></i>
            </div>
            <h1 class="fw-bold text-primary">Ticket #@Html.DisplayFor(model => model.Soporte.Id)</h1>
            <p class="text-muted">Detalles completos del ticket de soporte</p>
        </div>

        <!-- Detalles -->
        <div class="support-details">
            <div class="d-flex justify-content-between align-items-start py-3 border-bottom">
                <div class="fw-bold"><i class="fas fa-calendar-alt me-2 text-primary"></i>Fecha</div>
                <div class="text-muted">@Html.DisplayFor(model => model.Soporte.Fecha)</div>
            </div>
            <div class="d-flex justify-content-between align-items-start py-3 border-bottom">
                <div class="fw-bold"><i class="fas fa-list-alt me-2 text-primary"></i>Tipo</div>
                <div class="text-muted">@Html.DisplayFor(model => model.Soporte.Tipo)</div>
            </div>
            <div class="d-flex justify-content-between align-items-start py-3 border-bottom">
                <div class="fw-bold"><i class="fas fa-file-alt me-2 text-primary"></i>Descripción</div>
                <div class="text-muted glass-card-inner p-3 rounded-2 border-start border-4 border-primary flex-grow-1 ms-3 fst-italic">
                    @Html.DisplayFor(model => model.Soporte.Descripcion)
                </div>
            </div>
            <div class="d-flex justify-content-between align-items-start py-3 border-bottom">
                <div class="fw-bold"><i class="fas fa-reply me-2 text-primary"></i>Respuesta</div>
                <div class="text-muted flex-grow-1 ms-3">
                    @if (!String.IsNullOrEmpty(Model.Soporte.Respuesta) && Model.Soporte.Respuesta != "Pendiente")
                    {
                        <p class="mb-1">El equipo de soporte no ha respondido.</p>
                        <div class="glass-card-inner p-3 bg-secondary bg-opacity-10 rounded-2 border-start border-4 border-secondary fst-italic">
                            @Html.DisplayFor(model => model.Soporte.Respuesta)
                        </div>
                    }
                    else
                    {
                        <span class="text-muted"><em>Sin respuesta aún</em></span>
                    }
                </div>
            </div>
            <div class="d-flex justify-content-between align-items-center py-3 border-bottom">
                <div class="fw-bold"><i class="fas fa-user me-2 text-primary"></i>Usuario Creador</div>
                <div class="text-muted">@(Model.Soporte.IdUsuariosNavigation?.Nombre ?? "Desconocido")</div>
            </div>
            <div class="d-flex justify-content-between align-items-center py-3">
                <div class="fw-bold"><i class="fas fa-info-circle me-2 text-primary"></i>Estado</div>
                <div>
                    @if (!String.IsNullOrEmpty(Model.Soporte.Respuesta) && Model.Soporte.Respuesta != "Pendiente")
                    {
                        <span class="badge bg-success">Resuelto</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Pendiente</span>
                    }
                </div>
            </div>
        </div>

        <!-- Botón Volver -->
        <div class="text-center mt-4">
            <a asp-page="./Index" class="btn-secondary-custom">
                <i class="fas fa-arrow-left me-2"></i>Volver a la lista
            </a>
        </div>
    </div>
</div>
