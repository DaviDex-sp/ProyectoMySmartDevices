@page
@model ProyectoMSD.Pages.Soportes.CreateModel

@{
    ViewData["Title"] = "Nuevo Ticket de Soporte";
}

@section Styles {
    <link href="~/css/pages/soportes.css" rel="stylesheet" />
}

<div class="container" style="padding: 2rem 0;">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <!-- Banner: Usuario que envía el ticket (fuera del formulario) -->
            <div class="alert d-flex align-items-center mb-4 glass-card-inner border-primary p-3">
                <div class="rounded-circle bg-primary text-white btn-circle-md flex-shrink-0 fw-bold me-3 fs-5">
                    @(Model.UsuarioSesion?.Nombre?.Substring(0, 1).ToUpper() ?? "?")
                </div>
                <div>
                    <div class="fw-bold text-primary">
                        <i class="fas fa-user-check me-2"></i>Enviando como: @(Model.UsuarioSesion?.Nombre ?? "Desconocido")
                    </div>
                    <div class="small text-muted">
                        @(Model.UsuarioSesion?.Correo ?? "") &nbsp;·&nbsp; Sesión activa
                    </div>
                </div>
                <span class="badge bg-primary ms-auto px-3 py-2 small">
                    <i class="fas fa-lock me-1"></i>Asignado automáticamente
                </span>
            </div>

            <!-- Tarjeta del formulario -->
            <div class="card shadow-sm rounded-4 border-0">
                <div class="card-header bg-primary text-white p-4 border-0">
                    <h3 class="mb-1 fw-bold">
                        <i class="fas fa-ticket-alt me-2"></i>Crear Nuevo Ticket
                    </h3>
                    <p class="mb-0 text-white-50">Describe tu problema o consulta para recibir ayuda</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <!-- Fecha (automática, solo lectura — asignada por el servidor) -->
                        <div class="mb-3">
                            <label class="form-label">
                                <i class="fas fa-calendar-alt me-2 text-primary"></i>Fecha del Ticket
                            </label>
                            <input type="date" class="form-control" readonly
                                   value="@DateTime.Now.ToString("yyyy-MM-dd")" disabled>
                            <div class="form-text">
                                <i class="fas fa-info-circle me-1"></i>La fecha se asigna automáticamente al crear el ticket
                            </div>
                        </div>

                        <!-- Tipo de Consulta -->
                        <div class="mb-3">
                            <label asp-for="Input.Tipo" class="form-label">
                                <i class="fas fa-tags me-2 text-primary"></i>Tipo de Consulta
                            </label>
                            <select asp-for="Input.Tipo" class="form-select">
                                <option value="">Seleccionar tipo de consulta...</option>
                                <option value="consulta">❓ Consulta General</option>
                                <option value="problema">⚠️ Problema Técnico</option>
                                <option value="sugerencia">💡 Sugerencia</option>
                                <option value="instalacion">🔧 Ayuda con Instalación</option>
                                <option value="configuracion">⚙️ Configuración</option>
                                <option value="facturacion">💳 Facturación</option>
                            </select>
                            <span asp-validation-for="Input.Tipo" class="text-danger"></span>
                        </div>

                        <!-- Descripción del Problema -->
                        <div class="mb-4">
                            <label asp-for="Input.Descripcion" class="form-label">
                                <i class="fas fa-file-alt me-2 text-primary"></i>Descripción del Problema
                            </label>
                            <textarea asp-for="Input.Descripcion" class="form-control" rows="5"
                                      placeholder="Describe detalladamente tu problema o consulta. Incluye pasos que seguiste, mensajes de error, o cualquier información relevante..."></textarea>
                            <span asp-validation-for="Input.Descripcion" class="text-danger"></span>
                            <div class="form-text">
                                <i class="fas fa-lightbulb me-1"></i>Entre más detalles proporciones, mejor podremos ayudarte
                            </div>
                        </div>

                        <!-- Botones de Acción -->
                        <div class="d-flex justify-content-between">
                            <a asp-page="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Volver al Soporte
                            </a>
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-paper-plane me-2"></i>Crear Ticket
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}