@page
@model ProyectoMSD.Pages.Usuarios.DetailsModel

@{
    ViewData["Title"] = "Details";
}

@section Styles {
    <link href="~/css/pages/usuarios.css" rel="stylesheet" />
}

<h1 align="center">Detalles</h1>

<div>
    <h4>Detalles del Usuario</h4>
    <hr />
    <dl class="row align-content-md-center">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Usuario.Nombre)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Usuario.Nombre)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Usuario.Clave)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Usuario.Clave)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Usuario.Correo)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Usuario.Correo)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Usuario.Rol)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Usuario.Rol)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Usuario.Telefono)
        </dt>
        <dd class="col-sm-10">
            @(ProyectoMSD.Helpers.TelefonoHelper.ObtenerPrefijoConBandera(Model.Usuario.PrefijoTelefono)) @Html.DisplayFor(model => model.Usuario.Telefono)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Usuario.UbicacionNavigation.DireccionFormateada)
        </dt>
        <dd class="col-sm-10">
            @(Model.Usuario.UbicacionNavigation?.DireccionFormateada ?? "Dirección no registrada")
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Usuario.Permisos)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Usuario.Permisos)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Usuario.Documento)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Usuario.Documento)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Usuario.Rut)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Usuario.Rut)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Usuario.Acesso)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Usuario.Acesso)
        </dd>
    </dl>
</div>

<div class="mt-4">
    <h4>Propiedades Asociadas</h4>
    <hr />
    @if (Model.Usuario.UsuariosPropiedades != null && Model.Usuario.UsuariosPropiedades.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover rounded">
                <thead class="thead-dark">
                    <tr>
                        <th>Dirección</th>
                        <th>Tipo (Casa/Apt)</th>
                        <th>Rol en la Propiedad</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var up in Model.Usuario.UsuariosPropiedades)
                    {
                        <tr>
                            <td>@up.IdPropiedadNavigation?.Direccion</td>
                            <td>@up.IdPropiedadNavigation?.Tipo</td>
                            <td><span class="badge bg-info text-dark">@up.RolEnPropiedad</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">Este usuario aún no está asociado a ninguna propiedad.</p>
    }
</div>

<div class="mt-4">
    <a asp-page="./Edit" asp-route-id="@Model.Usuario.Id" class="btn btn-outline-primary">Editar</a> |
    <a asp-page="./Index" class="btn btn-warning">Volver a Usuarios</a>
</div>
