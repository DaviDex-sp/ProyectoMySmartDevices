@page
@model ProyectoMSD.Pages.Usuarios.DetailsModel

@{
    ViewData["Title"] = "Details";
}

@section Styles {
    <link href="~/css/pages/usuarios.css" rel="stylesheet" />
}

<div class="main-container">
    <div class="profile-header glass-card-header">
        <div class="d-flex align-items-center">
            <div class="avatar-container me-4">
                <div class="avatar-lg">
                    @(Model.Usuario?.Nombre?.Substring(0, 1).ToUpper() ?? "U")
                </div>
            </div>
            <div class="profile-info flex-grow-1">
                <h2 class="mb-2 theme-text-main">@(Model.Usuario?.Nombre ?? "Detalles de Usuario")</h2>
                <div class="profile-status text-muted">
                    Visualizando perfil de usuario
                </div>
            </div>
        </div>
    </div>

    <!-- Space Details -->
    <div class="form-container mt-4">
        <div class="form-header">
            <h3><i class="fas fa-info-circle me-2"></i>Información del Usuario</h3>
        </div>
        <div class="glass-card-inner p-4 mt-3">
            <div class="info-grid text-start">
                <div class="row w-100 m-0">
                    <div class="col-md-6 col-lg-3 mb-3">
                        <strong class="d-block theme-text-main"><i class="fas fa-envelope me-1"></i>Correo</strong>
                        <span class="theme-text-main">@Html.DisplayFor(model => model.Usuario.Correo)</span>
                    </div>
                    <div class="col-md-6 col-lg-3 mb-3">
                        <strong class="d-block theme-text-main"><i class="fas fa-user-tag me-1"></i>Rol</strong>
                        <span class="theme-text-main">@Html.DisplayFor(model => model.Usuario.Rol)</span>
                    </div>
                    <div class="col-md-6 col-lg-3 mb-3">
                        <strong class="d-block theme-text-main"><i class="fas fa-phone me-1"></i>Teléfono</strong>
                        <span class="theme-text-main">@(ProyectoMSD.Helpers.TelefonoHelper.ObtenerPrefijoConBandera(Model.Usuario.PrefijoTelefono)) @Html.DisplayFor(model => model.Usuario.Telefono)</span>
                    </div>
                    <div class="col-md-6 col-lg-3 mb-3">
                        <strong class="d-block theme-text-main"><i class="fas fa-map-marker-alt me-1"></i>Ubicación</strong>
                        <span class="theme-text-main">@(Model.Usuario.UbicacionNavigation?.DireccionFormateada ?? "Dirección no registrada")</span>
                    </div>
                    <div class="col-md-6 col-lg-3 mb-3">
                        <strong class="d-block theme-text-main"><i class="fas fa-shield-alt me-1"></i>Permisos</strong>
                        <span class="theme-text-main">@Html.DisplayFor(model => model.Usuario.Permisos)</span>
                    </div>
                    <div class="col-md-6 col-lg-3 mb-3">
                        <strong class="d-block theme-text-main"><i class="fas fa-id-card me-1"></i>Documento</strong>
                        <span class="theme-text-main">@Html.DisplayFor(model => model.Usuario.Documento)</span>
                    </div>
                    <div class="col-md-6 col-lg-3 mb-3">
                        <strong class="d-block theme-text-main"><i class="fas fa-building me-1"></i>RUT</strong>
                        <span class="theme-text-main">@Html.DisplayFor(model => model.Usuario.Rut)</span>
                    </div>
                    <div class="col-md-6 col-lg-3 mb-3">
                        <strong class="d-block theme-text-main"><i class="fas fa-toggle-on me-1"></i>Acceso</strong>
                        <span class="theme-text-main">@Html.DisplayFor(model => model.Usuario.Acesso)</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-5">
            <h4 class="theme-text-main mb-3"><i class="fas fa-city me-2 text-primary"></i>Propiedades Asociadas</h4>
            @if (Model.Usuario.UsuariosPropiedades != null && Model.Usuario.UsuariosPropiedades.Any())
            {
                <div class="table-responsive glass-card-inner rounded-3" style="overflow: hidden;">
                    <table class="table table-hover mb-0">
                        <thead class="table-borderless bg-black bg-opacity-10">
                            <tr>
                                <th class="theme-text-main border-0">Dirección</th>
                                <th class="theme-text-main border-0">Tipo</th>
                                <th class="theme-text-main border-0">Rol en la Propiedad</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var up in Model.Usuario.UsuariosPropiedades)
                            {
                                <tr>
                                    <td class="theme-text-main">@up.IdPropiedadNavigation?.Direccion</td>
                                    <td class="theme-text-main">@up.IdPropiedadNavigation?.Tipo</td>
                                    <td><span class="badge bg-secondary">@up.RolEnPropiedad</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-light border glass-card-inner text-muted mt-2 d-flex align-items-center">
                    <i class="fas fa-info-circle fa-2x me-3 opacity-50"></i>
                    <span>Este usuario aún no está asociado a ninguna propiedad.</span>
                </div>
            }
        </div>

        <div class="d-flex justify-content-between align-items-center mt-5">
            <a asp-page="./Index" class="btn-secondary-custom">
                <i class="fas fa-arrow-left me-2"></i>Volver a la lista
            </a>
            <a asp-page="./Edit" asp-route-id="@Model.Usuario.Id" class="btn-primary-custom">
                <i class="fas fa-edit me-2"></i>Editar Usuario
            </a>
        </div>
    </div>
</div>
