@page
@model ProyectoMSD.Pages.Usuarios.IndexModel

@{
    ViewData["Title"] = "Hogar Inteligente - Gestión de Usuarios";
}

@section Styles {
    <link href="~/css/pages/usuarios.css" rel="stylesheet" />
}

<!-- Contenido Principal -->
<div class="container-fluid px-4" style="padding-top: 20px;">

    @if (Model.RequiereInformacionBasica)
    {
        <div class="alert shadow-sm mb-4" style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); border-radius: 15px; border-left: 5px solid #258cfb; display: flex; align-items: center; justify-content: space-between;">
            <div>
                <h5 class="alert-heading text-primary fw-bold mb-1"><i class="fas fa-info-circle me-2"></i>Información Básica</h5>
                <p class="mb-0 text-muted">Alguna información básica es requerida, es necesario completar la información para el correcto funcionamiento.</p>
            </div>
            <div>
                <a asp-page="/Perfil/Index" class="btn btn-outline-primary" style="border-radius: 20px;" title="Mi Perfil">
                    <i class="fas fa-user-circle me-1"></i>
                    <span>Ir a Mi Perfil</span>
                </a>
            </div>
        </div>
    }

    <div class="hero-section text-center hero-background">
        <h1 class="display-4 fw-bold mb-4">BIENVENIDO A TU HOGAR INTELIGENTE</h1>
        <h3 class="mb-0">
            Tu hogar Gestiona actualmente
            <span class="fw-bold text-warning">@Model.TotalUsuarios Usuarios</span> en
            <span class="fw-bold text-warning">@Model.TotalEspacios Espacios</span> Diferentes
        </h3>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <!-- Cards de Estadísticas -->
        <div class="row mb-5">
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="stats-card text-center">
                    <div class="mb-3">
                        <i class="fas fa-users fa-4x text-primary"></i>
                    </div>
                    <h2 class="fw-bold text-primary mb-2">@Model.TotalUsuarios USUARIOS</h2>
                    <p class="text-success mb-1">
                        <i class="fas fa-arrow-up me-1"></i>
                        <strong>@Model.UsuariosActivos activos</strong> esta semana
                    </p>
                    <small class="text-muted">Usuarios registrados en el sistema</small>
                </div>
            </div>

            <div class="col-lg-4 col-md-6 mb-4">
                <div class="stats-card text-center">
                    <div class="mb-3">
                        <i class="fas fa-home fa-4x text-success"></i>
                    </div>
                    <h2 class="fw-bold text-success mb-2">@Model.TotalEspacios ESPACIOS</h2>
                    <p class="text-info mb-1">
                        <i class="fas fa-map-marked-alt me-1"></i>
                        <strong>Espacios configurados</strong> en hogar
                    </p>
                    <small class="text-muted">Áreas de control disponibles</small>
                </div>
            </div>

            <div class="col-lg-4 col-md-6 mb-4">
                <div class="stats-card text-center">
                    <div class="mb-3">
                        <i class="fas fa-mobile-alt fa-4x text-warning"></i>
                    </div>
                    <h2 class="fw-bold text-warning mb-2">@Model.TotalDispositivos DISPOSITIVOS</h2>
                    <p class="text-info mb-1">
                        <i class="fas fa-map-marked-alt me-1"></i>
                        <strong>@Model.DispositivosActivos Activos</strong> en hogar
                    </p>
                    <small class="text-muted">Total de dispositivos conectados</small>
                </div>
            </div>
        </div>

        <!-- Acciones Rápidas -->
        <div class="mb-5">
            <h4 class="text-white mb-4 d-flex align-items-center">
                <i class="fas fa-bolt me-3 fa-lg"></i>
                <span class="fw-bold">ACCIONES RÁPIDAS</span>
            </h4>

        <div class="table-container">
            <div class="table-header">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h3 class="mb-2 fw-bold">
                            <i class="fas fa-users me-3"></i>Gestión de Usuarios del Sistema
                        </h3>
                        <p class="mb-0 opacity-90 fs-5">Administra todos los usuarios registrados en tu hogar inteligente</p>
                    </div>
                    <div>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-page="Create" class="btn btn-light btn-lg">
                                <i class="fas fa-plus me-2"></i>Crear Nuevo Usuario
                            </a>
                        }
                    </div>
                </div>
            </div>

            <div class="p-4">
                @if (Model.Usuario != null && Model.Usuario.Any())
                {
                    <div class="row g-3">
                        @foreach (var item in Model.Usuario)
                        {
                            <div class="col-12">
                                <div class="card shadow-sm rounded-3">
                                    <div class="card-body d-flex align-items-center">
                                        <!-- Avatar -->
                                        <div class="avatar bg-primary text-white me-3 fs-4 d-flex justify-content-center align-items-center rounded-circle" style="width:50px; height:50px;">
                                            @(item.Nombre?.Substring(0, 1).ToUpper())
                                        </div>

                                        <!-- Info del usuario -->
                                        <div class="flex-grow-1">
                                            <h5 class="fw-bold mb-1">@Html.DisplayFor(modelItem => item.Nombre)</h5>
                                            <p class="mb-1 text-muted">
                                                <i class="fas fa-envelope me-2"></i>@Html.DisplayFor(modelItem => item.Correo)
                                            </p>
                                            <p class="mb-1">
                                                @{
                                                    var rolClass = item.Rol?.ToLower() switch
                                                    {
                                                        "admin" => "bg-danger text-white",
                                                        "administrador" => "bg-danger text-white",
                                                        "usuario" => "bg-success text-white",
                                                        "moderador" => "bg-warning text-dark",
                                                        _ => "bg-secondary text-white"
                                                    };
                                                }
                                                <span class="badge @rolClass">@Html.DisplayFor(modelItem => item.Rol)</span>
                                            </p>
                                            <p class="mb-1 text-muted">
                                                <i class="fas fa-phone me-2"></i>@(ProyectoMSD.Helpers.TelefonoHelper.ObtenerPrefijoConBandera(item.PrefijoTelefono)) @Html.DisplayFor(modelItem => item.Telefono)
                                            </p>
                                            <p class="mb-1 text-muted">
                                                <i class="fas fa-map-marker-alt me-2"></i>@Html.DisplayFor(modelItem => item.Ubicacion)
                                            </p>
                                            <p class="mb-1 text-muted">
                                                <i class="fas fa-id-card me-2"></i>@Html.DisplayFor(modelItem => item.Documento)
                                            </p>
                                            <p class="mb-1 text-muted">
                                                <i class="fas fa-building me-2"></i>@Html.DisplayFor(modelItem => item.Rut)
                                            </p>
                                            <p class="mb-0 fw-bold">
                                                @{
                                                    var accesoClass = item.Acesso?.ToLower() switch
                                                    {
                                                        "activo" => "text-success",
                                                        "active" => "text-success",
                                                        "biencaballo" => "text-success",
                                                        "yes" => "text-success",
                                                        "habilitado" => "text-success",
                                                        _ => "text-danger"
                                                    };

                                                    var accesoIcon = item.Acesso?.ToLower() switch
                                                    {
                                                        "activo" => "fa-check-circle",
                                                        "active" => "fa-check-circle",
                                                        "biencaballo" => "fa-check-circle",
                                                        "yes" => "fa-check-circle",
                                                        "habilitado" => "fa-check-circle",
                                                        _ => "fa-times-circle"
                                                    };
                                                }
                                                <i class="fas @accesoIcon me-2 @accesoClass"></i>@Html.DisplayFor(modelItem => item.Acesso)
                                            </p>
                                        </div>

                                        <!-- Botones de acción -->
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <div class="ms-3">
                                                <div class="btn-group" role="group">
                                                    <a asp-page="./Edit" asp-route-id="@item.Id"
                                                       class="btn btn-outline-primary btn-sm"
                                                       title="Editar usuario" data-bs-toggle="tooltip">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <a asp-page="./Delete" asp-route-id="@item.Id"
                                                       class="btn btn-outline-danger btn-sm"
                                                       title="Eliminar usuario" data-bs-toggle="tooltip">
                                                        <i class="fas fa-trash-alt"></i>
                                                    </a>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-users fa-4x mb-4 opacity-25"></i>
                        <h4 class="mb-3">No hay usuarios registrados</h4>
                        <p class="mb-4">Comienza agregando el primer usuario al sistema.</p>
                        <a asp-page="Create" class="btn btn-primary btn-lg">
                            <i class="fas fa-plus me-2"></i>Crear Primer Usuario
                        </a>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <!-- Vista Persuasiva / Motivacional para Usuarios -->
        <div class="row g-4 mb-5">
            <div class="col-12">
                <!-- Main Glass Card -->
                <div class="card border-0 shadow-lg" style="border-radius: 24px; overflow: hidden; background: rgba(255, 255, 255, 0.65); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.5); box-shadow: 0 15px 35px rgba(116, 81, 248, 0.1) !important;">
                    <div class="card-header border-0 p-4 p-lg-5" style="background: linear-gradient(135deg, #5e35b1 0%, #9c27b0 100%);">
                        <div class="d-flex align-items-center">
                            <div class="icon-shape bg-white text-primary rounded-circle me-4 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px; font-size: 1.8rem; box-shadow: 0 8px 20px rgba(0,0,0,0.15);">
                                <i class="fas fa-magic" style="color: #5e35b1;"></i>
                            </div>
                            <div>
                                <h2 class="mb-1 fw-bolder text-white" style="letter-spacing: -0.5px;">Descubre el Poder de tu Hogar</h2>
                                <p class="mb-0 text-white-50 fs-5">Tu entorno inteligente está listo para facilitarte la vida todos los días.</p>
                            </div>
                        </div>
                    </div>
                    <div class="card-body p-4 p-md-5">
                        <div class="row align-items-center">
                            <div class="col-lg-7 mb-4 mb-lg-0">
                                <h3 class="fw-bold mb-4" style="color: #3f2b96;">Automatiza tus Rutinas</h3>
                                <p class="text-secondary fs-5 mb-5" style="line-height: 1.7;">
                                    Controla luces, temperatura, seguridad y más desde un solo lugar. Con <strong>MySmartDevice</strong>, tu hogar se adapta a tu estilo de vida, brindándote un nivel superior de confort, seguridad y eficiencia energética.
                                </p>
                                <div class="d-flex flex-column flex-sm-row gap-3">
                                    <a asp-page="/Espacios/Index" class="btn btn-lg px-4 gap-3 fw-bold shadow-sm d-flex align-items-center justify-content-center" style="border-radius: 30px; background: linear-gradient(135deg, #5e35b1 0%, #9c27b0 100%); color: white; border: none; transition: transform 0.3s; min-width: 200px;">
                                        <i class="fas fa-home me-2"></i> Mis Espacios
                                    </a>
                                    <a asp-page="/Dispositivos/Index" class="btn btn-lg px-4 fw-bold d-flex align-items-center justify-content-center" style="border-radius: 30px; background: transparent; color: #5e35b1; border: 2px solid #5e35b1; transition: transform 0.3s; min-width: 200px;">
                                        <i class="fas fa-plug me-2"></i> Dispositivos
                                    </a>
                                </div>
                            </div>
                            <div class="col-lg-5 d-flex justify-content-center position-relative">
                                <!-- Glowing background behind icon -->
                                <div class="position-absolute" style="width: 250px; height: 250px; background: radial-gradient(circle, rgba(156, 39, 176, 0.2) 0%, rgba(255,255,255,0) 70%); top: 50%; left: 50%; transform: translate(-50%, -50%); border-radius: 50%;"></div>
                                <div class="robot-icon" style="width: 220px; height: 220px; background: rgba(255, 255, 255, 0.8); border: 2px solid rgba(255, 255, 255, 0.9); box-shadow: 0 15px 35px rgba(0,0,0,0.05); border-radius: 50%; display: flex; align-items: center; justify-content: center; position: relative; z-index: 1;">
                                    <i class="fas fa-laptop-house" style="font-size: 7rem; background: -webkit-linear-gradient(135deg, #5e35b1 0%, #9c27b0 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Beneficios Cards -->
            <div class="col-md-4">
                <div class="card text-center h-100 border-0" style="border-radius: 20px; background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(15px); box-shadow: 0 10px 30px rgba(0,0,0,0.04); transition: transform 0.3s, box-shadow 0.3s;">
                    <div class="card-body p-4 p-lg-5">
                        <div class="icon-circle mb-4 mx-auto" style="width: 70px; height: 70px; border-radius: 20px; background: linear-gradient(135deg, rgba(94, 53, 177, 0.1) 0%, rgba(156, 39, 176, 0.1) 100%); display: flex; align-items: center; justify-content: center; font-size: 2rem;">
                            <i class="fas fa-leaf" style="color: #673ab7;"></i>
                        </div>
                        <h4 class="fw-bold" style="color: #3f2b96;">Eficiencia Energética</h4>
                        <p class="text-muted mb-0 mt-3 fs-6">Reduce tu consumo y huella de carbono optimizando el uso de energía.</p>
                    </div>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="card text-center h-100 border-0" style="border-radius: 20px; background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(15px); box-shadow: 0 10px 30px rgba(0,0,0,0.04); transition: transform 0.3s, box-shadow 0.3s;">
                    <div class="card-body p-4 p-lg-5">
                        <div class="icon-circle mb-4 mx-auto" style="width: 70px; height: 70px; border-radius: 20px; background: linear-gradient(135deg, rgba(94, 53, 177, 0.1) 0%, rgba(156, 39, 176, 0.1) 100%); display: flex; align-items: center; justify-content: center; font-size: 2rem;">
                            <i class="fas fa-shield-alt" style="color: #ea4c89;"></i>
                        </div>
                        <h4 class="fw-bold" style="color: #3f2b96;">Seguridad Total</h4>
                        <p class="text-muted mb-0 mt-3 fs-6">Monitorea tu hogar 24/7 y recibe alertas en tiempo real sobre cualquier actividad inusual.</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card text-center h-100 border-0" style="border-radius: 20px; background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(15px); box-shadow: 0 10px 30px rgba(0,0,0,0.04); transition: transform 0.3s, box-shadow 0.3s;">
                    <div class="card-body p-4 p-lg-5">
                        <div class="icon-circle mb-4 mx-auto" style="width: 70px; height: 70px; border-radius: 20px; background: linear-gradient(135deg, rgba(94, 53, 177, 0.1) 0%, rgba(156, 39, 176, 0.1) 100%); display: flex; align-items: center; justify-content: center; font-size: 2rem;">
                            <i class="fas fa-couch" style="color: #9c27b0;"></i>
                        </div>
                        <h4 class="fw-bold" style="color: #3f2b96;">Confort Absoluto</h4>
                        <p class="text-muted mb-0 mt-3 fs-6">Prepara el ambiente perfecto antes de llegar, desde tu dispositivo móvil.</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>