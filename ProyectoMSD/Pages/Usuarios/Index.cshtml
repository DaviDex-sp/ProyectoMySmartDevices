@page
@model ProyectoMSD.Pages.Usuarios.IndexModel

@{
    ViewData["Title"] = "Gestión de Usuarios - MySmartDevice";
}

@section Styles {
    <link href="~/css/pages/usuarios.css" rel="stylesheet" />
}

<div class="container-fluid px-4 py-4">

    <!-- Alerta de Información Faltante -->
    @if (Model.RequiereInformacionBasica)
    {
        <div class="glass-container p-4 mb-4 border-start border-4 border-warning shadow-sm animate__animated animate__fadeIn">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <h5 class="fw-bold text-warning mb-1"><i class="fas fa-exclamation-triangle me-2"></i>Información Pendiente</h5>
                    <p class="mb-0 text-muted small">Tu perfil necesita datos adicionales (Documento o Teléfono) para habilitar todas las funciones inteligentes.</p>
                </div>
                <a asp-page="/Perfil/Index" class="btn btn-outline-warning rounded-pill px-4">
                    <i class="fas fa-user-edit me-2"></i>Completar Perfil
                </a>
            </div>
        </div>
    }

    <!-- Header Banner: Negro Puro / Glass -->
    <div class="usuarios-header-banner animate__animated animate__fadeInDown">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h1 class="display-5 fw-bold mb-2">Hogar Inteligente</h1>
                <p class="fs-5 opacity-75 mb-0">Gestión centralizada de accesos, seguridad y perfiles de usuario.</p>
                <div class="mt-4 pt-2">
                    <span class="badge bg-white bg-opacity-10 text-white px-3 py-2 rounded-pill border border-white border-opacity-10">
                        <i class="fas fa-microchip me-2"></i>Ecosistema: Conectado y Seguro
                    </span>
                </div>
            </div>
            <div class="col-lg-4 text-end d-none d-lg-block">
                <i class="fas fa-users-cog fa-6x opacity-25"></i>
            </div>
        </div>
    </div>

    <!-- Sección de Estadísticas / KPIs -->
    <div class="row g-4 mb-5 animate__animated animate__fadeIn">
        @if (Model.EsAdmin)
        {
            <!-- KPIs para Administrador -->
            <div class="col-xl-3 col-md-6">
                <div class="user-stats-card">
                    <h6 class="text-muted text-uppercase small fw-bold">Usuarios Totales</h6>
                    <h2 class="display-6 fw-bold text-primary mb-1">@Model.Metricas.TotalUsuarios</h2>
                    <p class="mb-0 small text-muted">Base de datos global</p>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="user-stats-card">
                    <h6 class="text-muted text-uppercase small fw-bold">Dispositivos</h6>
                    <h2 class="display-6 fw-bold text-success mb-1">@Model.Metricas.TotalDispositivos</h2>
                    <p class="mb-0 small text-muted">Hardware registrado</p>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="user-stats-card">
                    <h6 class="text-muted text-uppercase small fw-bold">Espacios</h6>
                    <h2 class="display-6 fw-bold text-info mb-1">@Model.Metricas.TotalEspacios</h2>
                    <p class="mb-0 small text-muted">Zonas inteligentes</p>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="user-stats-card">
                    <h6 class="text-muted text-uppercase small fw-bold">Soportes</h6>
                    <h2 class="display-6 fw-bold text-warning mb-1">@Model.Metricas.SoportesPendientes</h2>
                    <p class="mb-0 small text-muted">Pendientes de respuesta</p>
                </div>
            </div>
        }
        else
        {
            <!-- KPIs para Usuario Común -->
            <div class="col-xl-3 col-md-6">
                <div class="user-stats-card">
                    <h6 class="text-muted text-uppercase small fw-bold">Mis Propiedades</h6>
                    <h2 class="display-6 fw-bold text-primary mb-1">@Model.Metricas.TotalPropiedades</h2>
                    <p class="mb-0 small text-muted">Bajo tu control</p>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="user-stats-card">
                    <h6 class="text-muted text-uppercase small fw-bold">Mis Dispositivos</h6>
                    <h2 class="display-6 fw-bold text-success mb-1">@Model.Metricas.TotalDispositivos</h2>
                    <p class="mb-0 small text-muted">Configurados y activos</p>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="user-stats-card">
                    <h6 class="text-muted text-uppercase small fw-bold">Mis Espacios</h6>
                    <h2 class="display-6 fw-bold text-info mb-1">@Model.Metricas.TotalEspacios</h2>
                    <p class="mb-0 small text-muted">Zonas personalizadas</p>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="user-stats-card">
                    <h6 class="text-muted text-uppercase small fw-bold">Tickets Soporte</h6>
                    <h2 class="display-6 fw-bold text-warning mb-1">@Model.Metricas.TotalSoportes</h2>
                    <p class="mb-0 small text-muted">Historial de alertas</p>
                </div>
            </div>
        }
    </div>

    <!-- Actividad y Controles -->
    <div class="row g-4 mb-5">
        <!-- Actividad Reciente (Glass List) -->
        <div class="col-lg-7">
            <div class="glass-container p-4 h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-bold mb-0"><i class="fas fa-bolt me-2 text-primary"></i>Actividad del Sistema</h4>
                    <span class="badge bg-primary bg-opacity-25 text-primary">Últimas 5 acciones</span>
                </div>
                
                <div class="activity-feed">
                    @if (Model.UltimosAccesos != null && Model.UltimosAccesos.Any())
                    {
                        foreach (var acceso in Model.UltimosAccesos)
                        {
                            <div class="user-activity-item p-3 mb-3 d-flex align-items-center justify-content-between">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="user-avatar-circle" style="width: 40px; height: 40px; font-size: 0.9rem;">
                                        @(Model.EsAdmin ? acceso.IdUsuariosNavigation?.Nombre?.Substring(0,1).ToUpper() : "Yo")
                                    </div>
                                    <div>
                                        <p class="mb-0 fw-bold small text-white">@acceso.TipoAccion</p>
                                        <p class="mb-0 text-muted" style="font-size: 0.75rem;">
                                            <i class="fas fa-map-pin me-1"></i> @acceso.PaginaVisitada
                                        </p>
                                    </div>
                                </div>
                                <div class="text-end">
                                    <p class="mb-0 fw-bold small text-primary">@acceso.FechaAcceso.ToString("HH:mm")</p>
                                    <p class="mb-0 text-muted" style="font-size: 0.65rem;">@acceso.FechaAcceso.ToString("dd MMM")</p>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5 opacity-50">
                            <i class="fas fa-ghost fa-3x mb-3"></i>
                            <p>No hay actividad registrada aún.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Panel Informativo / Accesos Rápidos -->
        <div class="col-lg-5">
            <div class="user-info-panel h-100 d-flex flex-column justify-content-center">
                <h3 class="fw-bold mb-4">Descubre Tu Hogar</h3>
                <p class="text-muted fs-5 mb-4 mb-lg-5" style="line-height: 1.6;">Controla luces, seguridad y automatizaciones desde cualquier lugar con una estética centrada en la sofisticación.</p>
                <div class="d-grid gap-3">
                    <a asp-page="/Espacios/Index" class="btn btn-primary-custom btn-lg py-3 rounded-4">
                        <i class="fas fa-map me-2"></i>Gestionar Espacios
                    </a>
                    <a asp-page="/Dispositivos/Index" class="btn btn-secondary-custom btn-lg py-3 rounded-4">
                        <i class="fas fa-plug me-2"></i>Ver Dispositivos
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Lista de Usuarios (Solo visibles para Admin) -->
    @if (Model.EsAdmin)
    {
        <div class="mt-5 animate__animated animate__fadeInUp">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold mb-0 text-white"><i class="fas fa-users-cog me-2"></i>Directorio de Usuarios</h3>
                <a asp-page="Create" class="btn btn-primary-custom">
                    <i class="fas fa-plus me-2"></i>Nuevo Usuario
                </a>
            </div>

            <div class="user-list-wrapper">
                @if (Model.Usuario != null && Model.Usuario.Any())
                {
                    foreach (var item in Model.Usuario)
                    {
                        <div class="user-glass-card p-3">
                            <div class="d-flex align-items-center flex-wrap gap-4">
                                <div class="user-avatar-circle">
                                    @(item.Nombre?.Substring(0, 1).ToUpper() ?? "U")
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="fw-bold mb-1 text-white">@item.Nombre</h5>
                                    <div class="d-flex gap-3 text-muted small">
                                        <span><i class="fas fa-envelope me-1"></i> @item.Correo</span>
                                        <span><i class="fas fa-shield-alt me-1"></i> @item.Rol</span>
                                    </div>
                                </div>
                                <div class="text-end d-none d-md-block" style="min-width: 150px;">
                                    <p class="mb-1 text-white small"><i class="fas fa-phone me-1"></i> @item.Telefono</p>
                                    <p class="mb-0 text-muted small">@item.Acesso</p>
                                </div>
                                <div class="status-box">
                                    <span class="status-indicator @(item.Acesso?.ToLower() == "activo" ? "status-active" : "status-inactive")"></span>
                                    <span class="small fw-bold @(item.Acesso?.ToLower() == "activo" ? "text-success" : "text-danger")">
                                        @(item.Acesso?.ToUpper() ?? "UNKNOWN")
                                    </span>
                                </div>
                                <div class="ms-auto btn-group">
                                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light border-0"><i class="fas fa-edit"></i></a>
                                    <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger border-0"><i class="fas fa-trash-alt"></i></a>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="glass-container p-5 text-center opacity-50">
                        <p class="mb-0">No hay usuarios para mostrar en el directorio.</p>
                    </div>
                }
            </div>
        </div>
    }
</div>