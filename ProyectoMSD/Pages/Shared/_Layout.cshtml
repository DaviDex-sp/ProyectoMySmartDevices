<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProyectoMSD</title>
    <script type="importmap"></script>
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <!-- Estilos compartidos del proyecto -->
    <link href="~/css/common-styles.css" rel="stylesheet" />
    <!-- Sección para CSS específico de cada página -->
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        @if (ViewData["ShowNavbar"] == null || (ViewData["ShowNavbar"] as bool? == true))
        {
            <nav class="navbar navbar-expand-lg navbar-custom">
                <div class="container-fluid px-4">
                    <!-- Brand/Logo -->
                    <a class="navbar-brand d-flex align-items-center" asp-area="" asp-page="@((User?.Identity?.IsAuthenticated ?? false) ? "/Usuarios/Index" : "/Landing")">
                        <div class="brand-icon-wrapper">
                            <i class="fas fa-house-signal"></i>
                        </div>
                        <div class="brand-text-wrapper">
                            <span class="brand-name">My<span class="brand-accent">Smart</span>Device</span>
                        </div>
                    </a>

                    <!-- Botón hamburguesa para móviles -->
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                        <i class="fas fa-bars"></i>
                    </button>

                    <div class="collapse navbar-collapse" id="navbarNav">
                        <!-- Menú principal -->
                        <ul class="navbar-nav me-auto">
                            <!-- Inicio -->
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-area="" asp-page="/Index">
                                    <i class="fas fa-home"></i>
                                    <span>Inicio</span>
                                </a>
                            </li>

                            <!-- Dropdown: Gestión -->
                            <li class="nav-item dropdown">
                                <a class="nav-link nav-link-custom dropdown-toggle" href="#" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-th-large"></i>
                                    <span>Gestión</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-custom">
                                    <li>
                                        <a class="dropdown-item dropdown-item-custom" asp-page="/Usuarios/Index">
                                            <div class="dropdown-icon-box bg-purple"><i class="fas fa-users"></i></div>
                                            <div>
                                                <span class="dropdown-item-title">Usuarios</span>
                                                <small class="dropdown-item-desc">Gestionar cuentas</small>
                                            </div>
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item dropdown-item-custom" asp-page="/Propiedades/Index">
                                            <div class="dropdown-icon-box bg-green"><i class="fas fa-building"></i></div>
                                            <div>
                                                <span class="dropdown-item-title">Propiedades</span>
                                                <small class="dropdown-item-desc">Inmuebles registrados</small>
                                            </div>
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item dropdown-item-custom" asp-page="/Espacios/Index">
                                            <div class="dropdown-icon-box bg-cyan"><i class="fas fa-map-marked-alt"></i></div>
                                            <div>
                                                <span class="dropdown-item-title">Espacios</span>
                                                <small class="dropdown-item-desc">Zonas y áreas</small>
                                            </div>
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item dropdown-item-custom" asp-page="/Dispositivos/Index">
                                            <div class="dropdown-icon-box bg-orange"><i class="fas fa-microchip"></i></div>
                                            <div>
                                                <span class="dropdown-item-title">Dispositivos</span>
                                                <small class="dropdown-item-desc">IoT y sensores</small>
                                            </div>
                                        </a>
                                    </li>
                                </ul>
                            </li>

                            <!-- Dropdown: Sistema -->
                            <li class="nav-item dropdown">
                                <a class="nav-link nav-link-custom dropdown-toggle" href="#" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-cog"></i>
                                    <span>Sistema</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-custom">
                                    <li>
                                        <a class="dropdown-item dropdown-item-custom" asp-page="/Soportes/Index">
                                            <div class="dropdown-icon-box bg-red"><i class="fas fa-headset"></i></div>
                                            <div>
                                                <span class="dropdown-item-title">Soporte</span>
                                                <small class="dropdown-item-desc">Tickets y ayuda</small>
                                            </div>
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item dropdown-item-custom" asp-page="/Configuraciones/Index">
                                            <div class="dropdown-icon-box bg-indigo"><i class="fas fa-sliders-h"></i></div>
                                            <div>
                                                <span class="dropdown-item-title">Configuraciones</span>
                                                <small class="dropdown-item-desc">Ajustes del sistema</small>
                                            </div>
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item dropdown-item-custom" asp-page="/Privacy">
                                            <div class="dropdown-icon-box bg-slate"><i class="fas fa-shield-alt"></i></div>
                                            <div>
                                                <span class="dropdown-item-title">Privacidad</span>
                                                <small class="dropdown-item-desc">Términos y políticas</small>
                                            </div>
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        </ul>

                        <!-- Controles de la derecha -->
                        <div class="d-flex align-items-center gap-2 navbar-actions">
                            <!-- Tema Toggle -->
                            <button id="theme-toggle" class="btn btn-nav-theme-toggle" title="Cambiar modo de color">
                                <i class="fas fa-moon"></i>
                            </button>

                            <!-- Notificaciones -->
                            <a asp-page="/Notificaciones/Index" class="btn btn-nav-notification position-relative" title="Notificaciones">
                                <i class="fas fa-bell"></i>
                                @if (ViewData["NotifCount"] != null && (int?)ViewData["NotifCount"] > 0)
                                {
                                    <span class="notif-badge-count">@ViewData["NotifCount"]</span>
                                }
                            </a>
                            @if (User?.IsInRole("Admin") == false)
                            {
                                <!-- Mi Perfil (solo usuarios) -->
                                <a asp-page="/Perfil/Index" class="btn btn-nav-profile" title="Mi Perfil">
                                    <i class="fas fa-user-circle me-1"></i>
                                    <span class="d-none d-lg-inline">Mi Perfil</span>
                                </a>
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                <!-- Dashboard Admin -->
                                <a asp-page="/Dashboard/Index" class="btn btn-admin-dashboard" title="Dashboard Admin">
                                    <i class="fas fa-shield-alt me-1"></i>
                                    <span class="d-none d-xl-inline">Dashboard</span>
                                </a>
                            }
                            <!-- Logout -->
                            <a href="/Logout" class="btn btn-nav-logout">
                                <i class="fas fa-sign-out-alt me-1"></i>
                                <span class="d-none d-sm-inline">Salir</span>
                            </a>
                        </div>
                    </div>
                </div>
            </nav>
        }
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Footer Modernizado -->
    <footer class="footer border-top text-muted">
        <div class="container text-center py-3">
            <span>&copy; 2026 - MySmartDevice Dashboard - <a asp-page="/Privacidad" class="text-decoration-none">Privacidad</a></span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
