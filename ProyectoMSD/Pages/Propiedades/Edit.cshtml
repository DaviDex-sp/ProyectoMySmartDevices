@page
@model ProyectoMSD.Pages.Propiedades.EditModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    ViewData["Title"] = "Edit";
}

@section Styles {
    <link href="~/css/pages/propiedades.css" rel="stylesheet" />
}

<div class="main-container">
    <!-- Property Header -->
    <div class="glass-container p-4 mb-4 user-info-panel animate__animated animate__fadeInDown">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div class="d-flex align-items-center gap-4">
                <div class="btn-circle-md bg-gradient-primary shadow-sm text-white fs-2" style="width: 80px; height: 80px; position:relative;">
                    <i class="fas fa-home"></i>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark border border-white fs-7 shadow-sm">
                        EDIT
                    </span>
                </div>
                <div>
                    <h2 class="mb-1 theme-text-main fw-bold">@(Model.Propiedade?.Direccion ?? "Propiedad")</h2>
                    <div class="text-muted fw-bold small">
                        <i class="fas fa-spinner fa-spin me-1 text-primary"></i> Editando información de la propiedad
                    </div>
                </div>
            </div>
            
            <div class="d-flex gap-3">
                <div class="glass-card-inner px-4 py-2 d-flex flex-column text-center shadow-sm">
                    <i class="fas fa-building text-primary fs-5 mb-1"></i>
                    <span class="theme-text-main fw-bold">@(Model.Propiedade?.Tipo ?? "N/A")</span>
                    <small class="text-muted text-uppercase" style="font-size: 0.65rem;">Tipo</small>
                </div>
                <div class="glass-card-inner px-4 py-2 d-flex flex-column text-center shadow-sm">
                    <i class="fas fa-layer-group text-success fs-5 mb-1"></i>
                    <span class="theme-text-main fw-bold">@(Model.Propiedade?.Pisos ?? 0)</span>
                    <small class="text-muted text-uppercase" style="font-size: 0.65rem;">Niveles</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="content-wrapper">
        <!-- Form Section -->
        <div class="form-container">
            <div class="form-header">
                <h3>
                    <i class="fas fa-home"></i>
                    Información de la Propiedad
                </h3>
                <p>Actualiza los datos de la propiedad en el sistema de hogar inteligente</p>
            </div>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <input type="hidden" asp-for="Propiedade.Id" />

                <div class="form-grid">
                    <div class="form-group form-grid-full">
                        <label class="form-label mb-2">
                            <i class="fas fa-map-marked-alt me-1 text-primary"></i>Datos de Ubicación
                        </label>
                        <div class="alert alert-light border border-primary-subtle text-muted small mb-3">
                            <i class="fas fa-info-circle me-1 text-primary"></i> Haz clic en el mapa interactivo para cambiar la ubicación de esta propiedad.
                        </div>
                        <div id="map" class="map-container" style="height: 300px; border-radius: 12px; margin-bottom: 15px; border: 1px solid var(--glass-border); z-index: 1;"></div>
                        
                        <input type="hidden" asp-for="Latitud" id="latInput" />
                        <input type="hidden" asp-for="Longitud" id="lngInput" />
                        @* Binding DireccionFormateada to the text input so it acts like Direccion *@
                        <input type="hidden" asp-for="DireccionFormateada" id="hiddenDireccionFormateada" />

                        <div class="form-floating mb-2">
                            <input type="text" asp-for="Propiedade.Direccion" class="form-control shadow-sm rounded-3" id="direccionInput" placeholder="Dirección" />
                            <label asp-for="Propiedade.Direccion"><i class="fas fa-map-pin me-2 text-primary"></i>Dirección (Escribe y escoge de la lista)</label>
                        </div>
                        <span asp-validation-for="Propiedade.Direccion" class="text-danger fw-bold"></span>
                        <div id="loadingAddress" class="form-text text-primary d-none mt-2">
                            <i class="fas fa-spinner fa-spin me-1"></i> Buscando dirección exacta...
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-building me-1 text-primary"></i>Tipo de Propiedad
                        </label>
                        <select asp-for="Propiedade.Tipo" class="form-control">
                            <option value="">Seleccionar tipo...</option>
                            <option value="casa">🏠 Casa</option>
                            <option value="apartamento">🏢 Apartamento</option>
                            <option value="local">🏪 Local</option>
                            <option value="oficina">🏢 Oficina</option>
                            <option value="finca">🌿 Finca</option>
                        </select>
                        <span asp-validation-for="Propiedade.Tipo" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-layer-group me-1 text-primary"></i>Número de Pisos
                        </label>
                        <input asp-for="Propiedade.Pisos" type="number" class="form-control" placeholder="Ej: 2" min="1" max="50" />
                        <span asp-validation-for="Propiedade.Pisos" class="text-danger"></span>
                    </div>

                    <!-- Propietario gestionado en la seccion inferior -->
                </div>

                <div class="d-flex justify-content-between align-items-center mt-4">
                    <a asp-page="./Index" class="btn-secondary-custom">
                        <i class="fas fa-arrow-left me-2"></i>Volver a la lista
                    </a>
                    <button type="submit" class="btn-primary-custom">
                        <i class="fas fa-save me-2"></i>Guardar Cambios
                    </button>
                </div>
            </form>
        </div>

        <!-- Manage Users Section -->
        <div class="form-container mt-4">
            <div class="form-header">
                <h3>
                    <i class="fas fa-users"></i>
                    Usuarios Asociados (Residentes/Invitados)
                </h3>
                <p>Administra quién tiene acceso a controlar o ver esta propiedad</p>
            </div>

            @if (Model.Propiedade?.UsuariosPropiedades != null && Model.Propiedade.UsuariosPropiedades.Any())
            {
                <div class="table-responsive glass-card-inner rounded-3 mb-4" style="overflow: hidden;">
                    <table class="table table-hover mb-0">
                        <thead class="table-borderless" style="background: rgba(0,0,0,0.05);">
                            <tr>
                                <th class="theme-text-main border-0">Nombre</th>
                                <th class="theme-text-main border-0">Correo</th>
                                <th class="theme-text-main border-0">Rol</th>
                                <th class="theme-text-main border-0">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var up in Model.Propiedade.UsuariosPropiedades)
                            {
                                <tr>
                                    <td class="theme-text-main">@up.IdUsuarioNavigation?.Nombre</td>
                                    <td class="theme-text-main">@up.IdUsuarioNavigation?.Correo</td>
                                    <td><span class="badge bg-secondary">@up.RolEnPropiedad</span></td>
                                    <td>
                                        <form method="post" asp-page-handler="RemoveUser" class="d-inline">
                                            <input type="hidden" name="propId" value="@Model.Propiedade.Id" />
                                            <input type="hidden" name="userIdToRemove" value="@up.IdUsuario" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Seguro de remover este usuario de la propiedad?');">
                                                <i class="fas fa-trash"></i> Remover
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">No hay usuarios asociados aún (además del propietario principal).</div>
            }

            <hr />
            
            <h5 class="mb-3 theme-text-main">Añadir Nuevo Usuario</h5>
            <form method="post" asp-page-handler="AddUser" class="row g-3 align-items-end">
                <input type="hidden" name="propId" value="@Model.Propiedade.Id" />
                
                <div class="col-md-5">
                    <label class="form-label theme-text-main">Correo del Usuario</label>
                    <input type="email" name="emailUsuario" class="form-control" placeholder="usuario@correo.com" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label theme-text-main">Rol Asignado</label>
                    <select name="rolEnPropiedad" class="form-select">
                        <option value="Residente">Residente</option>
                        <option value="Propietario">Co-Propietario</option>
                        <option value="Invitado">Invitado</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-user-plus me-1"></i> Añadir
                    </button>
                </div>
            </form>
        </div>

        <!-- Activity Sidebar -->
        <div class="activity-sidebar">
            <div class="activity-header">Actividad Reciente</div>
            <div class="activity-item">
                <div class="activity-status">En progreso</div>
                <div class="activity-title">Editando información de propiedad</div>
                <a href="#" class="activity-action">Ver detalles</a>
            </div>
            <div class="activity-item">
                <div class="activity-status">Hace 15 minutos</div>
                <div class="activity-title">Propiedad actualizada</div>
                <div class="activity-action">Sistema</div>
            </div>
            <div class="activity-item">
                <div class="activity-status">Hace 1 hora</div>
                <div class="activity-title">Nuevo espacio agregado</div>
                <div class="activity-action">Configuración</div>
            </div>
            <div class="activity-item">
                <div class="activity-status">Hace 3 horas</div>
                <div class="activity-title">Dispositivos sincronizados</div>
                <div class="activity-action">Smart Home</div>
            </div>
            <div class="activity-item">
                <div class="activity-status">Hace 1 día</div>
                <div class="activity-title">Propietario actualizado</div>
                <div class="activity-action">Gestión</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://maps.googleapis.com/maps/api/js?key=@Configuration["GoogleCloud:MapsApiKey"]&libraries=places"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Update info cards when form values change
            document.querySelector('input[name="Propiedade.Direccion"]')?.addEventListener('input', function() {
                document.querySelector('.info-card:nth-child(1) .info-card-value').textContent = this.value || 'N/A';
                document.getElementById('hiddenDireccionFormateada').value = this.value;
            });
            document.querySelector('select[name="Propiedade.Tipo"]')?.addEventListener('change', function() {
                document.querySelector('.info-card:nth-child(2) .info-card-value').textContent = this.value || 'N/A';
            });
            document.querySelector('input[name="Propiedade.Pisos"]')?.addEventListener('input', function() {
                document.querySelector('.info-card:nth-child(3) .info-card-value').textContent = this.value ? `${this.value} pisos` : '0 pisos';
            });

            let startLat = parseFloat(document.getElementById('latInput').value);
            let startLng = parseFloat(document.getElementById('lngInput').value);

            if(isNaN(startLat) || isNaN(startLng)) {
                startLat = 4.6097;
                startLng = -74.0817;
            }

            const map = new google.maps.Map(document.getElementById('map'), {
                zoom: 14,
                center: { lat: startLat, lng: startLng },
                mapTypeControl: false,
                streetViewControl: false
            });

            const currentMarker = new google.maps.Marker({
                position: { lat: startLat, lng: startLng },
                map: map,
                draggable: true
            });

            const latInput = document.getElementById('latInput');
            const lngInput = document.getElementById('lngInput');
            const direccionInput = document.getElementById('direccionInput');
            const hiddenDireccionFormateada = document.getElementById('hiddenDireccionFormateada');
            const loadingAddress = document.getElementById('loadingAddress');
            const geocoder = new google.maps.Geocoder();

            // Configurar Autocomplete nativo de Google Places
            const autocomplete = new google.maps.places.Autocomplete(direccionInput, {
                componentRestrictions: { country: ["co", "us"] },
                fields: ["geometry", "formatted_address"]
            });

            autocomplete.addListener("place_changed", () => {
                const place = autocomplete.getPlace();
                if (!place.geometry || !place.geometry.location) {
                    return; // Enter presionado sin preselección
                }
                
                loadingAddress.classList.add('d-none');
                map.setCenter(place.geometry.location);
                map.setZoom(16);
                currentMarker.setPosition(place.geometry.location);
                
                const lat = place.geometry.location.lat();
                const lng = place.geometry.location.lng();
                
                latInput.value = lat.toFixed(8).replace(',', '.');
                lngInput.value = lng.toFixed(8).replace(',', '.');
                direccionInput.value = place.formatted_address;
                hiddenDireccionFormateada.value = place.formatted_address;
                document.querySelector('.info-card:nth-child(1) .info-card-value').textContent = place.formatted_address;
            });



            direccionInput.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                }
            });

            map.addListener('click', function(e) {
                const lat = e.latLng.lat();
                const lng = e.latLng.lng();
                currentMarker.setPosition(e.latLng);
                latInput.value = lat.toFixed(8).replace(',', '.');
                lngInput.value = lng.toFixed(8).replace(',', '.');
                obtenerDireccion(lat, lng);
            });
            
            currentMarker.addListener('dragend', function(e) {
                const lat = e.latLng.lat();
                const lng = e.latLng.lng();
                latInput.value = lat.toFixed(8).replace(',', '.');
                lngInput.value = lng.toFixed(8).replace(',', '.');
                obtenerDireccion(lat, lng);
            });

            function obtenerDireccion(lat, lng) {
                loadingAddress.classList.remove('d-none');
                geocoder.geocode({ location: { lat: lat, lng: lng } }, function(results, status) {
                    loadingAddress.classList.add('d-none');
                    if (status === 'OK' && results[0]) {
                        const direccionLimpia = results[0].formatted_address;
                        direccionInput.value = direccionLimpia;
                        hiddenDireccionFormateada.value = direccionLimpia;
                        document.querySelector('.info-card:nth-child(1) .info-card-value').textContent = direccionLimpia;
                        direccionInput.focus();
                    }
                });
            }
        });
    </script>
}