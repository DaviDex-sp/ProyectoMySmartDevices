@page
@model ProyectoMSD.Pages.Propiedades.CreateModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

        @{
        ViewData["Title"] = "Create";
        }
        
<div class="main-container">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="form-container">
                <div class="form-header">
                    <h3><i class="fas fa-home me-2"></i>Crear Nueva Propiedad</h3>
                    <p>Registra una nueva ubicación para tu hogar inteligente</p>
                </div>

                <!-- Google Maps will be loaded below -->

                <div class="form-content">
                    <form method="post">
                        <!-- MOSTRAR TODOS los errores -->
                        <div asp-validation-summary="All" class="alert alert-danger"></div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">
                                <i class="fas fa-map-marked-alt me-1 text-primary"></i>Datos de Ubicación
                            </label>
                            <div class="alert alert-light border border-primary-subtle text-muted small mb-3">
                                <i class="fas fa-info-circle me-1 text-primary"></i> Haz clic en el mapa interactivo para seleccionar la ubicación de esta propiedad.
                            </div>
                            <div id="map" class="map-container" style="height: 300px; border-radius: 12px; margin-bottom: 15px; border: 1px solid var(--glass-border); z-index: 1;"></div>
                            
                            <input type="hidden" asp-for="Latitud" id="latInput" />
                            <input type="hidden" asp-for="Longitud" id="lngInput" />

                            <div class="form-floating mb-2">
                                <input type="text" asp-for="Propiedade.Direccion" class="form-control shadow-sm rounded-3" id="direccionInput" placeholder="Dirección" />
                                <label asp-for="Propiedade.Direccion"><i class="fas fa-map-pin me-2 text-primary"></i>Dirección (Escribe y escoge de la lista)</label>
                            </div>
                            <span asp-validation-for="Propiedade.Direccion" class="text-danger fw-bold"></span>
                            <div id="loadingAddress" class="form-text text-primary d-none mt-2">
                                <i class="fas fa-spinner fa-spin me-1"></i> Buscando dirección exacta...
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="Propiedade.Tipo" class="form-label">
                                <i class="fas fa-building me-1 text-primary"></i>Tipo de Propiedad
                            </label>
                            <select asp-for="Propiedade.Tipo" class="form-select">
                                <option value="">Seleccionar tipo de propiedad...</option>
                                <option value="casa">🏠 Casa</option>
                                <option value="apartamento">🏢 Apartamento</option>
                                <option value="local">🏪 Local</option>
                                <option value="oficina">🏢 Oficina</option>
                                <option value="finca">🌿 Finca</option>
                            </select>
                            <span asp-validation-for="Propiedade.Tipo" class="text-danger fw-bold"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Propiedade.Pisos" class="form-label fw-bold">
                                <i class="fas fa-layer-group me-1"></i>Número de Pisos
                            </label>
                            <input asp-for="Propiedade.Pisos" type="number" min="1" class="form-control" placeholder="Ej: 2">
                            <span asp-validation-for="Propiedade.Pisos" class="text-danger fw-bold"></span>
                        </div>

                        <!-- DROPDOWN MEJORADO -->
                        <div class="mb-4">
                            <label asp-for="IdUsuarioSeleccionado" class="form-label fw-bold">
                                <i class="fas fa-user me-1"></i>Usuario Propietario
                            </label>
                            <select asp-for="IdUsuarioSeleccionado"
                                    class="form-select"
                                    asp-items="ViewBag.IdUsuarios">
                                <option value="">-- Seleccione un usuario --</option>
                            </select>
                            <span asp-validation-for="IdUsuarioSeleccionado" class="text-danger fw-bold"></span>
                            <div class="form-text">
                                <i class="fas fa-info-circle me-1"></i>Seleccione el usuario responsable de esta propiedad
                            </div>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-page="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-1"></i>Volver
                            </a>
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-save me-1"></i>Crear Propiedad
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://maps.googleapis.com/maps/api/js?key=@Configuration["GoogleCloud:MapsApiKey"]&libraries=places"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // -- Inicialización del Dropdown --
            const select = document.querySelector('select[name="IdUsuarioSeleccionado"]');
            console.log('=== DEBUGGING DROPDOWN ===');
            console.log('Opciones encontradas:', select?.options?.length || 0);

            if (select) {
                select.addEventListener('change', function() {
                    console.log('Usuario seleccionado:', this.value, this.options[this.selectedIndex].text);
                });
            }

            // -- Inicialización del Mapa --
            const defaultLat = 4.6097;
            const defaultLng = -74.0817;

            const map = new google.maps.Map(document.getElementById('map'), {
                zoom: 12,
                center: { lat: defaultLat, lng: defaultLng },
                mapTypeControl: false,
                streetViewControl: false
            });

            const currentMarker = new google.maps.Marker({
                position: { lat: defaultLat, lng: defaultLng },
                map: map,
                draggable: true
            });

            const latInput = document.getElementById('latInput');
            const lngInput = document.getElementById('lngInput');
            const direccionInput = document.getElementById('direccionInput');
            const loadingAddress = document.getElementById('loadingAddress');
            const geocoder = new google.maps.Geocoder();

            // Configurar Autocomplete nativo de Google Places
            const autocomplete = new google.maps.places.Autocomplete(direccionInput, {
                componentRestrictions: { country: ["co", "us"] },
                fields: ["geometry", "formatted_address"]
            });

            autocomplete.addListener("place_changed", () => {
                const place = autocomplete.getPlace();
                if (!place.geometry || !place.geometry.location) {
                    return; // Enter presionado sin preselección
                }
                
                loadingAddress.classList.add('d-none');
                map.setCenter(place.geometry.location);
                map.setZoom(16);
                currentMarker.setPosition(place.geometry.location);
                
                const lat = place.geometry.location.lat();
                const lng = place.geometry.location.lng();
                
                latInput.value = lat.toFixed(8).replace(',', '.');
                lngInput.value = lng.toFixed(8).replace(',', '.');
                direccionInput.value = place.formatted_address;
            });



            direccionInput.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                }
            });

            // --- Evento Click Normal ---
            map.addListener('click', function(e) {
                const lat = e.latLng.lat();
                const lng = e.latLng.lng();
                currentMarker.setPosition(e.latLng);
                latInput.value = lat.toFixed(8).replace(',', '.');
                lngInput.value = lng.toFixed(8).replace(',', '.');
                obtenerDireccion(lat, lng);
            });
            
            currentMarker.addListener('dragend', function(e) {
                const lat = e.latLng.lat();
                const lng = e.latLng.lng();
                latInput.value = lat.toFixed(8).replace(',', '.');
                lngInput.value = lng.toFixed(8).replace(',', '.');
                obtenerDireccion(lat, lng);
            });

            function obtenerDireccion(lat, lng) {
                loadingAddress.classList.remove('d-none');
                geocoder.geocode({ location: { lat: lat, lng: lng } }, function(results, status) {
                    loadingAddress.classList.add('d-none');
                    if (status === 'OK' && results[0]) {
                        direccionInput.value = results[0].formatted_address;
                        direccionInput.focus();
                    } else {
                        direccionInput.value = "";
                    }
                });
            }
        });
    </script>
}