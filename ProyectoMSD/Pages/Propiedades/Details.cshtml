@page
@model ProyectoMSD.Pages.Propiedades.DetailsModel

@{
    ViewData["Title"] = "Detalles de Propiedad";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/propiedades.css" />
}

<div class="container-fluid py-4 propiedad-details-container">
    <!-- Header principal -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="display-5 fw-bold theme-text-main mb-2">
                        <i class="fas fa-home me-3 text-primary"></i>Detalles de Propiedad
                    </h1>
                    <p class="text-secondary fs-5 mb-0">Información completa de esta ubicación</p>
                </div>
                <div class="text-end">
                    <a asp-page="./Index" class="btn btn-outline-dark fs-6 px-4 py-2 prop-btn-back">
                        <i class="fas fa-arrow-left me-2"></i>Volver al Listado
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg prop-card-main">
                <!-- Header de la Tarjeta -->
                <div class="card-header bg-primary bg-gradient text-white p-4 prop-card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h3 class="mb-0 fw-bold">
                            <i class="fas fa-map-marker-alt me-2"></i> @Model.Propiedade.Direccion
                        </h3>
                        @{
                            var tipoClass = Model.Propiedade.Tipo?.ToLower() switch
                            {
                                "casa" => "bg-success",
                                "apartamento" => "bg-primary",
                                "local" => "bg-warning text-dark",
                                "oficina" => "bg-info",
                                "finca" => "bg-danger",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @tipoClass fs-5 px-4 py-2 prop-badge-tipo">
                            @Model.Propiedade.Tipo
                        </span>
                    </div>
                </div>

                <div class="card-body p-5">
                    <div class="row mb-5">
                        <div class="col-md-6 mb-4 mb-md-0">
                            <div class="p-4 shadow-sm prop-info-box">
                                <h5 class="fw-bold text-primary mb-4 pb-2 prop-info-title">
                                    <i class="fas fa-info-circle me-2"></i>Información General
                                </h5>
                                <ul class="list-unstyled mb-0 fs-5">
                                    <li class="mb-4 d-flex align-items-center">
                                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm prop-icon-box">
                                            <i class="fas fa-building"></i>
                                        </div>
                                        <div>
                                            <small class="text-muted d-block fw-bold text-uppercase prop-label-text">Tipo de Propiedad</small>
                                            <span class="fw-bold theme-text-main fs-5">@Model.Propiedade.Tipo</span>
                                        </div>
                                    </li>
                                    <li class="d-flex align-items-center">
                                        <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm prop-icon-box">
                                            <i class="fas fa-layer-group"></i>
                                        </div>
                                        <div>
                                            <small class="text-muted d-block fw-bold text-uppercase prop-label-text">Número de Pisos</small>
                                            <span class="fw-bold theme-text-main fs-5">@Model.Propiedade.Pisos Nivel@(Model.Propiedade.Pisos > 1 ? "es" : "")</span>
                                        </div>
                                    </li>
                                </ul>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-4 shadow-sm prop-users-box">
                                <h5 class="fw-bold text-success mb-4 pb-2 prop-users-title">
                                    <i class="fas fa-users me-2"></i>Propietarios Asignados
                                </h5>
                                @if (Model.Propiedade.UsuariosPropiedades != null && Model.Propiedade.UsuariosPropiedades.Any())
                                {
                                    <div class="list-group list-group-flush bg-transparent">
                                        @foreach (var up in Model.Propiedade.UsuariosPropiedades)
                                        {
                                            var usuario = up.IdUsuarioNavigation;
                                            <div class="list-group-item px-0 py-3 d-flex align-items-center mb-2 prop-user-item border-0">
                                                <div class="avatar bg-success bg-gradient text-white rounded-circle ms-2 me-3 d-flex align-items-center justify-content-center shadow-sm fs-5 fw-bold prop-icon-box">
                                                    @(usuario?.Nombre?.Substring(0, 1).ToUpper() ?? "U")
                                                </div>
                                                <div class="flex-grow-1">
                                                    <h6 class="mb-0 fw-bold theme-text-main">@(usuario?.Nombre ?? "Usuario Desconocido")</h6>
                                                    <small class="text-muted">
                                                        <i class="fas fa-envelope me-1"></i>@(usuario?.Correo ?? "Sin correo")
                                                    </small>
                                                </div>
                                                <span class="badge bg-success bg-opacity-75 rounded-pill me-2">@(up.RolEnPropiedad ?? "Residente")</span>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="text-center text-muted py-5">
                                        <div class="rounded-circle shadow-sm d-inline-flex align-items-center justify-content-center mb-3 prop-empty-state-icon" style="background: var(--card-bg);">
                                            <i class="fas fa-user-slash fa-2x text-muted opacity-50"></i>
                                        </div>
                                        <p class="mb-0 fw-bold">No hay propietarios asignados.</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Sección de Espacios Conectados -->
                    <div class="row mt-4 mb-5">
                        <div class="col-12">
                            <div class="p-4 shadow-sm prop-spaces-box">
                                <h5 class="fw-bold mb-4 pb-2 prop-spaces-title">
                                    <i class="fas fa-cube me-2"></i>Espacios Conectados
                                </h5>
                                @if (Model.Propiedade.Espacios != null && Model.Propiedade.Espacios.Any())
                                {
                                    <div class="row g-3">
                                        @foreach (var espacio in Model.Propiedade.Espacios)
                                        {
                                            <div class="col-md-6 col-lg-4">
                                                <div class="card h-100 border-0 shadow-sm prop-space-card">
                                                    <div class="card-body p-3 d-flex align-items-center">
                                                        <div class="rounded-circle d-flex align-items-center justify-content-center me-3 prop-space-icon">
                                                            <i class="fas fa-door-open fs-5"></i>
                                                        </div>
                                                        <div>
                                                            <h6 class="fw-bold mb-1 text-dark fs-5">@espacio.Nombre</h6>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="text-center text-muted py-4">
                                        <div class="rounded-circle shadow-sm d-inline-flex align-items-center justify-content-center mb-3 prop-icon-box" style="background: var(--card-bg);">
                                            <i class="fas fa-store-slash fa-2x text-muted opacity-50"></i>
                                        </div>
                                        <p class="mb-0 fw-bold">Sin espacios conectados a esta propiedad.</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Footer Actions -->
                    <div class="d-flex justify-content-between align-items-center pt-4 border-top border-dash border-opacity-10">
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-page="./Edit" asp-route-id="@Model.Propiedade.Id" class="btn btn-primary btn-lg px-4 shadow-sm prop-btn-edit">
                                <i class="fas fa-edit me-2"></i>Editar Propiedad
                            </a>
                        }
                        else
                        {
                            <div></div> <!-- Espacio para empujar el otro botón si hubiera -->
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
