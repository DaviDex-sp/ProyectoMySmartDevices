@page
@model ProyectoMSD.Pages.Propiedades.DetailsModel

@{
    ViewData["Title"] = "Detalles de Propiedad";
    Layout = "_Layout";

    var tipo = Model.Propiedade.Tipo?.ToLower() ?? "";
    var badgeClass = tipo switch
    {
        "casa"        => "badge-tipo-casa",
        "apartamento" => "badge-tipo-apto",
        "local"       => "badge-tipo-local",
        "oficina"     => "badge-tipo-oficina",
        "finca"       => "badge-tipo-finca",
        _             => "badge-tipo-default"
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/propiedades.css" />
}

<!-- =====================================================
     HEADER BANNER — Sistema de diseño del proyecto
     ===================================================== -->
<div class="prop-page-header mb-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div class="d-flex align-items-center gap-3">
            <div class="prop-header-icon">
                <i class="fas fa-building"></i>
            </div>
            <div>
                <h1 class="fw-bold mb-0" style="font-size:1.9rem;">Detalles de Propiedad</h1>
                <p class="mb-0 opacity-75" style="font-size:0.95rem;">
                    <i class="fas fa-map-marker-alt me-1"></i>@Model.Propiedade.Direccion
                </p>
            </div>
        </div>
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <span class="prop-tipo-badge @badgeClass">
                <i class="fas fa-tag me-1"></i>@Model.Propiedade.Tipo
            </span>
            <span class="prop-pisos-badge">
                <i class="fas fa-layer-group me-1"></i>@Model.Propiedade.Pisos Piso@(Model.Propiedade.Pisos > 1 ? "s" : "")
            </span>
            @if (User.IsInRole("Admin"))
            {
                <a asp-page="./Edit" asp-route-id="@Model.Propiedade.Id" class="btn-primary-custom">
                    <i class="fas fa-edit me-1"></i>Editar
                </a>
            }
            <a asp-page="./Index" class="btn-secondary-custom">
                <i class="fas fa-arrow-left me-1"></i>Volver
            </a>
        </div>
    </div>
</div>

<!-- =====================================================
     CONTENIDO PRINCIPAL
     ===================================================== -->
<div class="row g-4 mb-4">

    <!-- Panel: Información General -->
    <div class="col-md-6">
        <div class="prop-detail-panel h-100">
            <div class="prop-detail-panel-header">
                <i class="fas fa-info-circle me-2"></i>Información General
            </div>
            <div class="prop-detail-panel-body">

                <div class="prop-detail-row">
                    <div class="prop-detail-icon-box prop-icon-blue">
                        <i class="fas fa-building"></i>
                    </div>
                    <div>
                        <small class="prop-detail-label">Tipo de Propiedad</small>
                        <div class="prop-detail-value">@Model.Propiedade.Tipo</div>
                    </div>
                </div>

                <div class="prop-detail-row">
                    <div class="prop-detail-icon-box prop-icon-green">
                        <i class="fas fa-layer-group"></i>
                    </div>
                    <div>
                        <small class="prop-detail-label">Número de Pisos</small>
                        <div class="prop-detail-value">
                            @Model.Propiedade.Pisos Nivel@(Model.Propiedade.Pisos > 1 ? "es" : "")
                        </div>
                    </div>
                </div>

                <div class="prop-detail-row">
                    <div class="prop-detail-icon-box prop-icon-purple">
                        <i class="fas fa-users"></i>
                    </div>
                    <div>
                        <small class="prop-detail-label">Propietarios Asignados</small>
                        <div class="prop-detail-value">
                            @(Model.Propiedade.UsuariosPropiedades?.Count ?? 0) persona@(Model.Propiedade.UsuariosPropiedades?.Count != 1 ? "s" : "")
                        </div>
                    </div>
                </div>

                <div class="prop-detail-row">
                    <div class="prop-detail-icon-box prop-icon-cyan">
                        <i class="fas fa-cube"></i>
                    </div>
                    <div>
                        <small class="prop-detail-label">Espacios Conectados</small>
                        <div class="prop-detail-value">
                            @(Model.Propiedade.Espacios?.Count ?? 0) espacio@(Model.Propiedade.Espacios?.Count != 1 ? "s" : "")
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- Panel: Propietarios Asignados -->
    <div class="col-md-6">
        <div class="prop-detail-panel h-100">
            <div class="prop-detail-panel-header prop-header-green">
                <i class="fas fa-users me-2"></i>Propietarios Asignados
            </div>
            <div class="prop-detail-panel-body">
                @if (Model.Propiedade.UsuariosPropiedades != null && Model.Propiedade.UsuariosPropiedades.Any())
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var up in Model.Propiedade.UsuariosPropiedades)
                        {
                            var usuario = up.IdUsuarioNavigation;
                            var inicial = usuario?.Nombre?.Substring(0, 1).ToUpper() ?? "U";
                            <div class="prop-user-card">
                                <div class="prop-user-avatar">@inicial</div>
                                <div class="flex-grow-1">
                                    <div class="fw-semibold theme-text-main">
                                        @(usuario?.Nombre ?? "Usuario Desconocido")
                                    </div>
                                    <small class="text-muted">
                                        <i class="fas fa-envelope me-1 opacity-60"></i>
                                        @(usuario?.Correo ?? "Sin correo")
                                    </small>
                                </div>
                                <span class="prop-rol-badge">
                                    @(up.RolEnPropiedad ?? "Residente")
                                </span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="prop-empty-panel">
                        <div class="prop-empty-panel-icon">
                            <i class="fas fa-user-slash"></i>
                        </div>
                        <p class="text-muted mb-0">Sin propietarios asignados</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- =====================================================
     ESPACIOS CONECTADOS
     ===================================================== -->
<div class="prop-detail-panel mb-4">
    <div class="prop-detail-panel-header prop-header-purple">
        <i class="fas fa-cube me-2"></i>Espacios Conectados
        @if (Model.Propiedade.Espacios != null && Model.Propiedade.Espacios.Any())
        {
            <span class="prop-count-badge ms-2">@Model.Propiedade.Espacios.Count</span>
        }
    </div>
    <div class="prop-detail-panel-body">
        @if (Model.Propiedade.Espacios != null && Model.Propiedade.Espacios.Any())
        {
            <div class="row g-3">
                @foreach (var espacio in Model.Propiedade.Espacios)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="prop-space-tile">
                            <div class="prop-space-icon">
                                <i class="fas fa-door-open text-white"></i>
                            </div>
                            <div>
                                <div class="fw-semibold theme-text-main">@espacio.Nombre</div>
                                @if (!string.IsNullOrEmpty(espacio.Permisos))
                                {
                                    <small class="text-muted">@espacio.Permisos</small>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="prop-empty-panel">
                <div class="prop-empty-panel-icon">
                    <i class="fas fa-cube"></i>
                </div>
                <p class="text-muted mb-0">Sin espacios conectados a esta propiedad</p>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-page="/Espacios/Create" class="btn-primary-custom mt-3">
                        <i class="fas fa-plus me-1"></i>Agregar Espacio
                    </a>
                }
            </div>
        }
    </div>
</div>
