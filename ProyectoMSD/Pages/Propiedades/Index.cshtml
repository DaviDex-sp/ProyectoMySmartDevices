@page
@model ProyectoMSD.Pages.Propiedades.IndexModel

@{
    ViewData["Title"] = "Propiedades";
    Layout = "_Layout";
}
@section Styles {
    <link href="~/css/pages/propiedades.css" rel="stylesheet" />
}

<!-- ========================================================
     HEADER BANNER — Sistema de diseño Glassmorphism
     Alineado con Usuarios/Index.cshtml (usuarios-header-banner)
     ======================================================== -->
<div class="usuarios-header-banner mb-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <div class="d-flex align-items-center gap-3 mb-2">
                <div class="icon-container-lg">
                    <i class="fas fa-building"></i>
                </div>
                <div>
                    <h1 class="fw-bold mb-0" style="font-size: 2rem;">Propiedades</h1>
                    <p class="mb-0 opacity-75">Gestión de propiedades del sistema de hogar inteligente</p>
                </div>
            </div>
        </div>
        <div class="d-flex gap-3 flex-wrap align-items-center">
            <div class="prop-stat-badge">
                <i class="fas fa-home me-2"></i>
                <span class="fw-bold">@Model.TotalPropiedades</span>
                <span class="opacity-75 ms-1">Total</span>
            </div>
            @if (User.IsInRole("Admin"))
            {
                <a asp-page="/Propiedades/Create" class="btn-primary-custom d-flex align-items-center gap-2">
                    <i class="fas fa-plus"></i>
                    Registrar Propiedad
                </a>
            }
        </div>
    </div>
</div>

<!-- ========================================================
     BUSCADOR GLASSMORPHISM — Filtro en tiempo real
     ======================================================== -->
<div class="prop-search-container mb-4">
    <div class="position-relative">
        <i class="fas fa-search prop-search-icon"></i>
        <input type="text"
               id="propSearch"
               class="form-control prop-search-input"
               placeholder="Buscar por dirección, propietario o tipo..."
               autocomplete="off" />
        <span id="propSearchCount" class="prop-search-badge">@Model.TotalPropiedades</span>
    </div>
</div>

<!-- ========================================================
     GRID DE TARJETAS DE PROPIEDADES
     ======================================================== -->
<div class="row g-4 mb-5" id="propiedadesGrid">
    @if (Model.PropiedadesDto != null && Model.PropiedadesDto.Any())
    {
        @foreach (var item in Model.PropiedadesDto)
        {
            <div class="col-xl-4 col-lg-6 col-md-12 prop-card-wrapper"
                 data-search="@item.Direccion.ToLower() @item.PropietarioNombre.ToLower() @item.Tipo.ToLower()">
                <div class="property-glass-card h-100 rounded-4 overflow-hidden d-flex flex-column">

                    <!-- Imagen/Header de la tarjeta -->
                    <div class="position-relative prop-card-hero">
                        <div class="prop-card-overlay d-flex align-items-center justify-content-center">
                            <i class="fas fa-home fa-3x text-white opacity-50"></i>
                        </div>
                        <!-- Badge tipo -->
                        <div class="position-absolute top-0 start-0 m-3">
                            @{
                                string badgeClass = "bg-secondary";
                                var t = item.Tipo?.ToLower() ?? "";
                                if(t == "casa") badgeClass = "bg-success";
                                else if(t == "apartamento") badgeClass = "bg-primary";
                                else if(t == "local") badgeClass = "bg-warning text-dark";
                                else if(t == "oficina") badgeClass = "bg-info";
                                else if(t == "finca") badgeClass = "bg-danger";
                            }
                            <span class="badge @badgeClass fs-6 px-3 py-2 rounded-pill shadow-sm">
                                <i class="fas fa-tag me-1"></i>@item.Tipo
                            </span>
                        </div>
                        <!-- Badge pisos -->
                        <div class="position-absolute top-0 end-0 m-3">
                            <span class="badge prop-badge-dark fs-6 px-3 py-2 rounded-pill shadow-sm">
                                <i class="fas fa-layer-group me-1"></i>@item.Pisos Piso@(item.Pisos > 1 ? "s" : "")
                            </span>
                        </div>
                    </div>

                    <!-- Contenido de la tarjeta -->
                    <div class="card-body p-4 d-flex flex-column flex-grow-1">

                        <!-- Dirección -->
                        <h4 class="card-title fw-bold mb-3 text-primary-custom">
                            <i class="fas fa-map-marker-alt me-2"></i>@item.Direccion
                        </h4>

                        <!-- Propietario -->
                        <div class="d-flex align-items-center mb-3 p-3 glass-card-inner rounded-3">
                            <div class="user-avatar-circle me-3">
                                @item.PropietarioInicial
                            </div>
                            <div class="flex-grow-1">
                                <h6 class="mb-1 fw-bold theme-text-main">
                                    <i class="fas fa-user me-1 text-primary-custom"></i>Propietario
                                </h6>
                                <p class="mb-0 text-muted small">@item.PropietarioNombre</p>
                                @if (!string.IsNullOrEmpty(item.PropietarioCorreo))
                                {
                                    <small class="text-muted fst-italic">
                                        <i class="fas fa-envelope me-1 opacity-50"></i>@item.PropietarioCorreo
                                    </small>
                                }
                            </div>
                        </div>

                        <!-- Mini-stats -->
                        <div class="prop-stats-row mb-4">
                            <div class="prop-stat-item">
                                <div class="fw-bold text-primary-custom fs-5">@item.ConsumoEnergeticoSimulado.ToString("F1")kW</div>
                                <small class="text-muted">Consumo</small>
                            </div>
                            <div class="prop-stat-item prop-stat-divider">
                                <div class="fw-bold text-success fs-5">@item.TotalDispositivos</div>
                                <small class="text-muted">Dispositivos</small>
                            </div>
                            <div class="prop-stat-item">
                                <div class="fw-bold text-info fs-5">@item.TotalEspacios</div>
                                <small class="text-muted">Espacios</small>
                            </div>
                        </div>

                        <!-- Botones de acción — Sistema de diseño del proyecto -->
                        <div class="d-flex gap-2 mt-auto flex-wrap">
                            <a asp-page="./Details" asp-route-id="@item.Id"
                               class="btn-primary-custom btn-sm flex-fill text-center"
                               title="Ver detalles">
                                <i class="fas fa-eye me-1"></i>Ver
                            </a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-page="./Edit" asp-route-id="@item.Id"
                                   class="btn-secondary-custom btn-sm flex-fill text-center"
                                   title="Editar propiedad">
                                    <i class="fas fa-edit me-1"></i>Editar
                                </a>
                                <button type="button"
                                        class="btn-danger-custom btn-sm"
                                        title="Eliminar propiedad"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteModal"
                                        data-property-id="@item.Id"
                                        data-property-address="@item.Direccion">
                                    <i class="fas fa-trash"></i>
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <!-- Empty State -->
        <div class="col-12">
            <div class="text-center py-5">
                <div class="prop-empty-state mx-auto">
                    <div class="prop-empty-icon mb-4">
                        <i class="fas fa-home fa-3x opacity-50"></i>
                    </div>
                    <h3 class="theme-text-main mb-2">Sin propiedades registradas</h3>
                    <p class="text-muted mb-4">Comienza agregando la primera propiedad al sistema de hogar inteligente</p>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-page="Create" class="btn-primary-custom">
                            <i class="fas fa-plus me-2"></i>Registrar Primera Propiedad
                        </a>
                    }
                </div>
            </div>
        </div>
    }
</div>

<!-- Sin resultados de búsqueda -->
<div id="noResultsMsg" class="text-center py-5 d-none">
    <div class="prop-empty-state mx-auto">
        <i class="fas fa-search fa-3x text-muted mb-3 opacity-50"></i>
        <h4 class="theme-text-main">Sin coincidencias</h4>
        <p class="text-muted">Intenta con otro término de búsqueda</p>
    </div>
</div>

<!-- ========================================================
     MODAL DE CONFIRMACIÓN — Eliminar Propiedad
     ======================================================== -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg glass-card p-0">
            <div class="modal-header border-0" style="background: var(--danger-gradient);">
                <h5 class="modal-title fw-bold text-white" id="deleteModalLabel">
                    <i class="fas fa-exclamation-triangle me-2"></i>Confirmar Eliminación
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-4 text-center glass-card-header">
                <i class="fas fa-home fa-4x text-danger mb-3 opacity-75"></i>
                <h5 class="mb-3 theme-text-main">¿Eliminar esta propiedad?</h5>
                <p class="text-muted mb-2">
                    Dirección: <span id="propertyAddress" class="fw-bold theme-text-main"></span>
                </p>
                <div class="alert border-0 mt-3" style="background: rgba(239,68,68,0.08); color: var(--text-dark);">
                    <i class="fas fa-exclamation-triangle me-2 text-danger"></i>
                    <strong>Esta acción no se puede deshacer.</strong> Se eliminarán todos los datos relacionados.
                </div>
            </div>
            <div class="modal-footer justify-content-center border-0 bg-card-item">
                <button type="button" class="btn-secondary-custom" data-bs-dismiss="modal">
                    <i class="fas fa-times me-2"></i>Cancelar
                </button>
                <form method="post" id="deleteForm" style="display:inline">
                    <input type="hidden" name="handler" value="Delete" />
                    <button type="submit" class="btn-danger-custom">
                        <i class="fas fa-trash me-2"></i>Sí, Eliminar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    // --- Modal de confirmación ---
    document.addEventListener('DOMContentLoaded', function () {
        const deleteModal = document.getElementById('deleteModal');
        const deleteForm  = document.getElementById('deleteForm');
        const propAddress = document.getElementById('propertyAddress');

        if (deleteModal) {
            deleteModal.addEventListener('show.bs.modal', function (event) {
                const btn = event.relatedTarget;
                const id  = btn.getAttribute('data-property-id');
                const addr = btn.getAttribute('data-property-address');
                if (propAddress) propAddress.textContent = addr;
                if (deleteForm)  deleteForm.action = './Delete?id=' + id;
            });
        }

        // --- Filtro de búsqueda en tiempo real ---
        const searchInput = document.getElementById('propSearch');
        const cards       = document.querySelectorAll('.prop-card-wrapper');
        const countBadge  = document.getElementById('propSearchCount');
        const noResults   = document.getElementById('noResultsMsg');

        if (searchInput) {
            searchInput.addEventListener('input', function () {
                const term    = this.value.trim().toLowerCase();
                let visible   = 0;

                cards.forEach(card => {
                    const data = card.getAttribute('data-search') || '';
                    const show = !term || data.includes(term);
                    card.style.display = show ? '' : 'none';
                    if (show) visible++;
                });

                // Actualizar badge y mensaje vacío
                if (countBadge) countBadge.textContent = visible;
                if (noResults) {
                    noResults.classList.toggle('d-none', visible > 0 || cards.length === 0);
                }
            });
        }
    });
</script>
