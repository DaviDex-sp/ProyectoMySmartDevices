@page
@model ProyectoMSD.Pages.Propiedades.IndexModel

@{
    ViewData["Title"] = "Propiedades";
    Layout = "_Layout";
}
@section Styles {
    <link href="~/css/pages/propiedades.css" rel="stylesheet" />
}

<div class="container-fluid py-4 min-vh-100 propiedades-container">

    <!-- Header principal -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4 p-4 glass-card">
                <div>
                    <h1 class="display-5 fw-bold text-main mb-2">
                        <i class="fas fa-building me-3 text-primary-custom"></i>Propiedades Registradas
                    </h1>
                    <p class="text-muted fs-5 mb-0">Gestiona todas las propiedades del sistema de hogar inteligente</p>
                </div>
                <div class="text-end">
                    <span class="badge bg-primary-custom fs-6 px-3 py-2">
                        <i class="fas fa-home me-2"></i>@Model.TotalPropiedades Propiedades Totales
                    </span>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm glass-card">
                <div class="card-body p-4">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <h5 class="mb-2 fw-bold text-primary-custom">
                                <i class="fas fa-cogs me-2"></i>Gestión de Propiedades
                            </h5>
                            <p class="text-muted mb-0">Administra y controla todas las propiedades de hogar inteligente desde aquí</p>
                        </div>
                        <div class="col-md-4 text-md-end">
                            <div class="d-flex gap-2 justify-content-center justify-content-md-end">
                                <!-- Botón para crear nueva propiedad -->
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-page="/Propiedades/Create" class="btn btn-primary-custom">
                                        <i class="fas fa-plus me-2"></i>Registrar Nueva Propiedad
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Cards de propiedades -->
    <div class="row g-4 mb-5">
        @if (Model.PropiedadesDto != null && Model.PropiedadesDto.Any())
        {
            @foreach (var item in Model.PropiedadesDto)
            {
                <div class="col-xl-4 col-lg-6 col-md-12">
                    <div class="card border-0 shadow-lg h-100 property-card glass-card p-0 overflow-hidden d-flex flex-column">
                        <!-- Imagen de la propiedad -->
                        <div class="position-relative property-img-container">
                            <div class="d-flex align-items-center justify-content-center h-100 property-img-overlay">
                                <i class="fas fa-home fa-4x text-white opacity-75"></i>
                            </div>
                            <!-- Badge del tipo de propiedad -->
                            <div class="position-absolute top-0 start-0 m-3">
                                <span class="badge @item.BadgeClass fs-6 px-3 py-2 rounded-pill shadow-sm">
                                    <i class="fas fa-tag me-2"></i>@item.Tipo
                                </span>
                            </div>

                            <!-- Badge del número de pisos -->
                            <div class="position-absolute top-0 end-0 m-3">
                                <span class="badge bg-dark bg-opacity-75 fs-6 px-3 py-2 rounded-pill shadow-sm text-light">
                                    <i class="fas fa-layer-group me-2"></i>@item.Pisos Piso@(item.Pisos > 1 ? "s" : "")
                                </span>
                            </div>
                        </div>

                        <!-- Contenido de la tarjeta -->
                        <div class="card-body p-4 d-flex flex-column flex-grow-1">
                            <!-- Título de la dirección -->
                            <h4 class="card-title fw-bold mb-3 text-primary-custom">
                                <i class="fas fa-map-marker-alt me-2"></i>@item.Direccion
                            </h4>

                            <!-- Información del usuario propietario -->
                            <div class="d-flex align-items-center mb-3 p-3 bg-card-item rounded-3">
                                <div class="avatar bg-primary-custom text-white rounded-circle me-3 d-flex align-items-center justify-content-center fw-bold shadow-sm"
                                     style="width: 45px; height: 45px; font-size: 18px;">
                                     @item.PropietarioInicial
                                </div>
                                <div class="flex-grow-1">
                                    <h6 class="mb-1 fw-bold text-main">
                                        <i class="fas fa-user me-2 opacity-50"></i>Propietario
                                    </h6>
                                    <p class="mb-0 text-muted small">
                                        @item.PropietarioNombre
                                    </p>
                                    @if (!string.IsNullOrEmpty(item.PropietarioCorreo))
                                    {
                                        <small class="text-muted fst-italic">
                                            <i class="fas fa-envelope me-1 opacity-50"></i>@item.PropietarioCorreo
                                        </small>
                                    }
                                </div>
                            </div>

                            <!-- Detalles adicionales -->
                            <div class="row g-3 mb-4 flex-grow-1">
                                <div class="col-6">
                                    <div class="text-center p-3 h-100 rounded-3 bg-opacity-10 bg-success border-color-custom border">
                                        <i class="fas fa-building text-success fa-2x mb-2"></i>
                                        <div class="fw-bold text-main">Tipo</div>
                                        <small class="text-muted">@item.Tipo</small>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="text-center p-3 h-100 rounded-3 bg-opacity-10 bg-warning border-color-custom border">
                                        <i class="fas fa-layer-group text-warning fa-2x mb-2"></i>
                                        <div class="fw-bold text-main">Pisos</div>
                                        <small class="text-muted">@item.Pisos nivel@(item.Pisos > 1 ? "es" : "")</small>
                                    </div>
                                </div>
                            </div>

                            <!-- Estadísticas simuladas -->
                            <div class="row text-center mb-4 mx-0 py-3 bg-card-item rounded-3 border-color-custom border">
                                <div class="col-4 px-1">
                                    <div class="fw-bold text-primary-custom fs-5">@item.ConsumoEnergeticoSimulado.ToString("F1")kW</div>
                                    <small class="text-muted" style="font-size: 0.75rem;">Consumo</small>
                                </div>
                                <div class="col-4 px-1 border-start border-end border-color-custom">
                                    <div class="fw-bold text-success fs-5">@item.TotalDispositivos</div>
                                    <small class="text-muted" style="font-size: 0.75rem;">Dispositivos</small>
                                </div>
                                <div class="col-4 px-1">
                                    <div class="fw-bold text-info fs-5">@item.TotalEspacios</div> 
                                    <small class="text-muted" style="font-size: 0.75rem;">Espacios</small>
                                </div>
                            </div>

                            <!-- Botones de acción -->
                            <div class="d-flex gap-2 justify-content-between mt-auto">
                                <div class="btn-group flex-fill" role="group">
                                    <a asp-page="./Details" asp-route-id="@item.Id"
                                       class="btn btn-outline-info" title="Ver detalles">
                                        <i class="fas fa-eye me-1"></i>Ver
                                    </a>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a asp-page="./Edit" asp-route-id="@item.Id"
                                           class="btn btn-outline-primary" title="Editar propiedad">
                                            <i class="fas fa-edit me-1"></i>Editar
                                        </a>
                                        <button type="button" 
                                           class="btn btn-outline-danger" 
                                           title="Eliminar propiedad"
                                           data-bs-toggle="modal" 
                                           data-bs-target="#deleteModal"
                                           data-property-id="@item.Id"
                                           data-property-address="@item.Direccion">
                                            <i class="fas fa-trash me-1"></i>Eliminar
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <!-- Estado vacío -->
            <div class="col-12">
                <div class="text-center py-5">
                    <div class="card border-0 shadow-sm mx-auto glass-card" style="max-width: 600px;">
                        <div class="card-body p-5">
                            <i class="fas fa-home fa-4x text-muted mb-4 opacity-50"></i>
                            <h3 class="text-main mb-3">No hay propiedades registradas</h3>
                            <p class="text-muted mb-4">Comienza agregando la primera propiedad al sistema de hogar inteligente</p>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-page="Create" class="btn btn-primary-custom btn-lg">
                                    <i class="fas fa-plus me-2"></i>Registrar Nueva Propiedad
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Modal de confirmación para eliminar -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg glass-card p-0">
            <div class="modal-header bg-danger text-white border-0">
                <h5 class="modal-title fw-bold" id="deleteModalLabel">
                    <i class="fas fa-exclamation-triangle me-2"></i>Confirmar Eliminación
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-4 text-center">
                <i class="fas fa-home fa-4x text-danger mb-3 opacity-75"></i>
                <h5 class="mb-3 text-main">¿Estás seguro de eliminar esta propiedad?</h5>
                <p class="text-muted mb-2">
                    Dirección: <span id="propertyAddress" class="fw-bold text-main"></span>
                </p>
                <div class="alert alert-warning mt-3 border-0 bg-warning bg-opacity-10 text-main">
                    <i class="fas fa-exclamation-triangle me-2 text-warning"></i>
                    <strong>Esta acción no se puede deshacer.</strong> Se eliminarán todos los datos relacionados.
                </div>
            </div>
            <div class="modal-footer justify-content-center border-0 bg-card-item">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-2"></i>Cancelar
                </button>
                <form method="post" id="deleteForm" style="display:inline">
                    <input type="hidden" name="handler" value="Delete" />
                    <button type="submit" class="btn btn-danger hover-danger">
                        <i class="fas fa-trash me-2"></i>Sí, Eliminar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- JavaScript para funcionalidad -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Configurar modal de eliminación
        const deleteModal = document.getElementById('deleteModal');
        const deleteForm = document.getElementById('deleteForm');
        const propertyAddress = document.getElementById('propertyAddress');

        if(deleteModal) {
            deleteModal.addEventListener('show.bs.modal', function(event) {
                const button = event.relatedTarget;
                const propertyId = button.getAttribute('data-property-id');
                const address = button.getAttribute('data-property-address');

                if(propertyAddress) propertyAddress.textContent = address;
                if(deleteForm) deleteForm.action = './Delete?id=' + propertyId;
            });
        }
    });
</script>
