@page
@model ProyectoMSD.Pages.Perfil.IndexModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Mi Perfil";
}

@section Styles {
    <link href="~/css/pages/perfil.css" rel="stylesheet" />
}

<!-- Profile Header -->
<!-- Profile Main Content -->
<div class="container-fluid px-4" style="padding-top: 20px;">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-1" style="color: #6a4cd5; font-size: 2.2rem; letter-spacing: -0.5px;">Perfil de Usuario</h1>
            <p class="text-secondary fs-5 mb-0">Gestiona tu información personal y preferencias</p>
        </div>
        <button type="button" class="btn btn-outline-secondary d-flex align-items-center gap-2 px-4 shadow-sm bg-white" style="border-radius: 20px;" onclick="document.getElementById('editProfileForm').scrollIntoView({behavior: 'smooth'})">
            <i class="fas fa-edit"></i> Editar
        </button>
    </div>

    <!-- Mensaje de éxito -->
    @if (!string.IsNullOrEmpty(Model.MensajeExito))
    {
        <div class="alert perfil-alert-success">
            <i class="fas fa-check-circle me-2"></i>@Model.MensajeExito
        </div>
    }

    <!-- Content Grid -->
    <!-- Content Grid -->
    <div class="row g-4 mt-2">
        <!-- Columna Izquierda: Información Personal -->
        <div class="col-lg-7 col-xl-8">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 20px; background: white;">
                <div class="card-body p-4 p-md-5">
                    <h5 class="text-secondary mb-4" style="font-weight: 500;">Información Personal</h5>
                    
                    <div class="d-flex flex-wrap align-items-center mb-5 gap-4">
                        <!-- Avatar púrpura grande -->
                        <div class="avatar text-white fs-1 d-flex justify-content-center align-items-center rounded-circle" style="width:100px; height:100px; background: linear-gradient(135deg, #a855f7 0%, #8b5cf6 100%); flex-shrink: 0; box-shadow: 0 10px 25px rgba(139, 92, 246, 0.3);">
                            @(Model.Usuario?.Nombre?.Substring(0, 2).ToUpper() ?? "US")
                        </div>
                        
                        <div>
                            <div class="d-flex align-items-center gap-3 mb-1">
                                <h3 class="fw-bold mb-0" style="color: #4b5563;">@(Model.Usuario?.Nombre ?? "Usuario")</h3>
                                @{
                                    var rolClass = Model.Usuario?.Rol?.ToLower() switch
                                    {
                                        "admin" => "bg-danger",
                                        "administrador" => "bg-danger",
                                        "usuario" => "bg-success",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge rounded-pill @rolClass px-3 py-1 bg-opacity-10" style="color: currentColor; border: 1px solid currentColor;">@Model.Usuario?.Rol</span>
                            </div>
                            <p class="text-muted mb-0">Miembro desde @(DateTime.Now.ToString("dd MMM yyyy"))</p>
                            @if (Model.Usuario?.Acesso == "activo")
                            {
                                <p class="text-success small mb-0"><i class="fas fa-circle me-1" style="font-size:0.5rem"></i>Activo ahora</p>
                            }
                        </div>
                    </div>

                    <hr style="border-color: #e5e7eb; margin: 2rem 0;">

                    <div class="row g-4">
                        <div class="col-md-6">
                            <p class="text-secondary fw-bold mb-2 small">Correo electrónico</p>
                            <div class="d-flex align-items-center">
                                <i class="fas fa-envelope text-muted me-3"></i>
                                <span style="color: #4b5563;">@(Model.Usuario?.Correo ?? "No registrado")</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <p class="text-secondary fw-bold mb-2 small">Teléfono</p>
                            <div class="d-flex align-items-center">
                                <i class="fas fa-phone-alt text-muted me-3"></i>
                                <span style="color: #4b5563;">@(ProyectoMSD.Helpers.TelefonoHelper.ObtenerPrefijoConBandera(Model.Usuario?.PrefijoTelefono)) @(Model.Usuario?.Telefono ?? "No registrado")</span>
                            </div>
                        </div>
                        <div class="col-md-12 mt-4">
                            <p class="text-secondary fw-bold mb-2 small">Dirección / Ubicación</p>
                            <div class="d-flex align-items-center">
                                <i class="fas fa-map-marker-alt text-muted me-3"></i>
                                <span style="color: #4b5563;">@(Model.Usuario?.Ubicacion ?? "No registrada")</span>
                            </div>
                        </div>
                        <div class="col-md-6 mt-4">
                            <p class="text-secondary fw-bold mb-2 small">RUT</p>
                            <div class="d-flex align-items-center">
                                <i class="fas fa-building text-muted me-3"></i>
                                <span style="color: #4b5563;">@(Model.Usuario?.Rut ?? "No registrado")</span>
                            </div>
                        </div>
                        <div class="col-md-6 mt-4">
                            <p class="text-secondary fw-bold mb-2 small">Documento Identidad</p>
                            <div class="d-flex align-items-center">
                                <i class="fas fa-id-card text-muted me-3"></i>
                                <span style="color: #4b5563;">@(Model.Usuario?.Documento?.ToString("N0") ?? "No registrado")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Columna Derecha: Dispositivos / Propiedades Conectadas -->
        <div class="col-lg-5 col-xl-4">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 20px; background: white;">
                <div class="card-body p-4 p-md-5">
                    <h5 class="text-secondary mb-4" style="font-weight: 500;">Propiedades Conectadas</h5>
                    
                    <div class="activity-feed">
                        @if (Model.Usuario?.Propiedades != null && Model.Usuario.Propiedades.Any())
                        {
                            @foreach (var propiedad in Model.Usuario.Propiedades.Take(4))
                            {
                                <div class="d-flex align-items-center p-3 mb-3 rounded-3" style="background: rgba(248, 249, 250, 0.7);">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px; background: rgba(139, 92, 246, 0.1); color: #8b5cf6;">
                                        <i class="fas fa-home"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0" style="color: #4b5563; font-weight: 600;">@propiedad.Direccion</h6>
                                        <small class="text-muted">@(propiedad.Tipo ?? "Residencial") • @propiedad.Pisos Pisos</small>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-4 text-muted">
                                <div class="mb-3">
                                    <div class="rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px; background: rgba(139, 92, 246, 0.1); color: #8b5cf6;">
                                        <i class="fas fa-plug fs-3"></i>
                                    </div>
                                </div>
                                No tienes propiedades conectadas actualmente.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Formulario de Edición (Heredado y Estilizado) -->
    <div class="row mt-4 mb-5" id="editProfileForm">
        <div class="col-12">
            <div class="card border-0 shadow-sm" style="border-radius: 20px; background: white;">
                <div class="card-body p-4 p-md-5">
                    <h5 class="text-secondary mb-4" style="font-weight: 500;">
                        <i class="fas fa-user-edit text-primary me-2"></i>Editar Información
                    </h5>
                    
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3"></div>

                        <!-- Campos ocultos -->
                        <input type="hidden" asp-for="Usuario.Id" />
                        <input type="hidden" asp-for="Usuario.Rol" />
                        <input type="hidden" asp-for="Usuario.Permisos" />
                        <input type="hidden" asp-for="Usuario.Documento" />
                        <input type="hidden" asp-for="Usuario.Rut" />
                        <input type="hidden" asp-for="Usuario.Acesso" />
                        <input type="hidden" asp-for="Usuario.Clave" />

                        <div class="row g-4">
                            <!-- Nombre -->
                            <div class="col-md-6">
                                <label class="form-label text-secondary small fw-bold">Nombre Completo</label>
                                <input asp-for="Usuario.Nombre" class="form-control px-4 py-2 bg-light border-0" style="border-radius: 12px;" />
                                <span asp-validation-for="Usuario.Nombre" class="text-danger small"></span>
                            </div>

                            <!-- Correo -->
                            <div class="col-md-6">
                                <label class="form-label text-secondary small fw-bold">Correo Electrónico</label>
                                <input asp-for="Usuario.Correo" type="email" class="form-control px-4 py-2 bg-light border-0" style="border-radius: 12px;" />
                                <span asp-validation-for="Usuario.Correo" class="text-danger small"></span>
                            </div>

                            <!-- Teléfono -->
                            <div class="col-md-6">
                                <label class="form-label text-secondary small fw-bold">Teléfono Móvil</label>
                                <div class="input-group" style="background: var(--bs-light); border-radius: 12px; overflow: hidden;">
                                    <select asp-for="Usuario.PrefijoTelefono" class="form-select border-0 bg-transparent text-center" style="max-width: 130px; box-shadow: none;">
                                        <option value="+57">🇨🇴 +57</option>
                                        <option value="+1">🇺🇸 +1</option>
                                        <option value="+52">🇲🇽 +52</option>
                                        <option value="+34">🇪🇸 +34</option>
                                    </select>
                                    <input asp-for="Usuario.Telefono" type="number" class="form-control border-0 bg-transparent" style="box-shadow: none;" />
                                </div>
                            </div>

                            <!-- Ubicación -->
                            <div class="col-md-6">
                                <label class="form-label text-secondary small fw-bold">Ciudad / Ubicación</label>
                                <select asp-for="Usuario.Ubicacion" class="form-select px-4 py-2 bg-light border-0" style="border-radius: 12px;">
                                    <option value="">Seleccionar ciudad...</option>
                                    <option value="Bogotá">Bogotá</option>
                                    <option value="Medellín">Medellín</option>
                                    <option value="Cali">Cali</option>
                                    <option value="Barranquilla">Barranquilla</option>
                                </select>
                                <span asp-validation-for="Usuario.Ubicacion" class="text-danger small"></span>
                            </div>

                            <!-- Cambio de Contraseña -->
                            <div class="col-12 mt-4">
                                <div class="p-4 rounded-3" style="background: rgba(139, 92, 246, 0.05); border: 1px dashed rgba(139, 92, 246, 0.3);">
                                    <p class="text-muted fw-bold mb-3 small"><i class="fas fa-lock me-2"></i>Seguridad de Contraseña</p>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <input type="password" name="NuevaClave" class="form-control px-4 py-2 bg-white border-0" style="border-radius: 12px;" placeholder="Nueva contraseña (opcional)" />
                                            <small class="text-muted mt-2 d-block">Déjalo en blanco para no cambiar tu clave actual.</small>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Botón Guardar -->
                            <div class="col-12 mt-4 d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary px-5 py-2 fw-bold" style="border-radius: 30px; background: linear-gradient(135deg, #5e35b1 0%, #9c27b0 100%); border: none; box-shadow: 0 10px 20px rgba(94, 53, 177, 0.2);">
                                    <i class="fas fa-save me-2"></i>Guardar Cambios
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Toggle password visibility
    function togglePassword() {
        const input = document.getElementById('nuevaClave');
        const icon = document.querySelector('.fa-eye, .fa-eye-slash');
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.replace('fa-eye', 'fa-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.replace('fa-eye-slash', 'fa-eye');
        }
    }
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
